<view class="tabbar-wrap safe-bottom {{hidden ? 'tabbar--hidden' : ''}}">
  <view class="tabbar">
    <view class="tabbar-bg"></view>
    <view class="tabbar-row">
      <view
        wx:for="{{list}}"
        wx:key="pagePath"
        class="tab {{selected === index ? 'tab--on' : ''}}"
        data-index="{{index}}"
        data-path="{{item.pagePath}}"
        bindtap="switchTab"
      >
        <text class="tab-glyph" wx:if="{{item.text === '首页'}}">⌂</text>
        <text class="tab-glyph" wx:elif="{{item.text === '分类'}}">≡</text>
        <text class="tab-glyph" wx:elif="{{item.text === '购物袋'}}">🛍</text>
        <text class="tab-glyph" wx:else>☻</text>
      </view>
    </view>
  </view>
</view>
