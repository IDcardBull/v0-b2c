.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #EFE8DC;
  padding-top: 12rpx;
  z-index: 99;
  transform: translateY(0);
  transition: transform 0.25s ease;
}
.tabbar--hidden {
  transform: translateY(120%);
  pointer-events: none;
}

.tabbar-line {
  height: 1rpx;
  background: rgba(58, 58, 58, 0.08);
  margin: 0 60rpx;
}

.tabbar-row {
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  padding: 16rpx 0 20rpx;
}

.tab {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 8rpx 0;
}

.dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 0.25s ease;
}

.tab--on .dot {
  background: #3A3A3A;
  width: 10rpx;
  height: 10rpx;
}

.tab-label {
  font-family: "Songti SC", "STSong", serif;
  font-size: 26rpx;
  letter-spacing: 8rpx;
  color: #A69F92;
  padding-left: 8rpx;
}

.tab--on .tab-label {
  color: #3A3A3A;
}

.badge {
  position: absolute;
  top: 4rpx;
  right: 50%;
  transform: translateX(36rpx);
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: #3A3A3A;
  color: #EFE8DC;
  font-size: 20rpx;
  font-family: "PingFang SC", sans-serif;
  line-height: 28rpx;
  text-align: center;
  letter-spacing: 0;
}
