/* 中式贴底 TabBar */
.tabbar-wrap {
  position: fixed;
  left: 0; right: 0;
  bottom: 0;
  z-index: 99;
  background: #FBF7EE;
  border-top: 1rpx solid rgba(58,58,58,0.08);
  box-shadow: 0 -2rpx 12rpx rgba(58,58,58,0.04);
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(0);
  transition: transform 0.35s ease;
}
.tabbar--hidden { transform: translateY(110%); }
.tabbar {
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  padding: 10rpx 0 6rpx;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 4rpx 0;
  transition: transform 0.18s ease;
}
.tab:active { transform: scale(0.92); }
.tab-icon {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ic { position: relative; width: 48rpx; height: 48rpx; }

/* 通用：未选浅墨色，选中深墨色 */
.tab .stroke,
.eaves, .pillar, .floor,
.rhomb,
.bag-handle, .bag-body, .bag-line,
.seal-out, .seal-in {
  border-color: #9C9385;
  background-color: transparent;
  transition: all 0.2s ease;
}
.tab--on .eaves,
.tab--on .pillar,
.tab--on .floor,
.tab--on .rhomb,
.tab--on .bag-handle,
.tab--on .bag-body,
.tab--on .bag-line,
.tab--on .seal-out,
.tab--on .seal-in {
  border-color: #2B2B2B;
}

/* 首页：屋檐 + 立柱 + 地基（中式建筑剪影） */
.ic-home { display: flex; flex-direction: column; align-items: center; justify-content: center; }
.eaves {
  width: 0; height: 0;
  border-left: 26rpx solid transparent;
  border-right: 26rpx solid transparent;
  border-bottom: 12rpx solid #9C9385;
  position: relative;
}
.tab--on .eaves { border-bottom-color: #2B2B2B; }
.eaves::after {
  content: '';
  position: absolute;
  left: -32rpx; right: -32rpx; top: 12rpx;
  height: 2rpx;
  background: #9C9385;
}
.tab--on .eaves::after { background: #2B2B2B; }
.pillar {
  position: absolute;
  width: 2rpx;
  height: 22rpx;
  top: 18rpx;
  background: #9C9385;
}
.pillar-l { left: 14rpx; }
.pillar-r { right: 14rpx; }
.tab--on .pillar { background: #2B2B2B; }
.floor {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx; right: 8rpx;
  height: 2rpx;
  background: #9C9385;
}
.tab--on .floor { background: #2B2B2B; }

/* 分类：双菱方胜纹 */
.ic-cat { display: flex; align-items: center; justify-content: center; }
.rhomb {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border: 1.5rpx solid #9C9385;
  transform: rotate(45deg);
}
.rhomb-1 { left: 4rpx; top: 12rpx; }
.rhomb-2 { right: 4rpx; top: 12rpx; }

/* 购物：竹篮（半圆把手 + 梯形篮身 + 一道横纹） */
.ic-bag { display: flex; flex-direction: column; align-items: center; }
.bag-handle {
  width: 22rpx;
  height: 12rpx;
  border: 1.5rpx solid #9C9385;
  border-bottom: none;
  border-radius: 22rpx 22rpx 0 0;
  margin-top: 4rpx;
}
.bag-body {
  width: 36rpx;
  height: 26rpx;
  border: 1.5rpx solid #9C9385;
  border-radius: 4rpx 4rpx 8rpx 8rpx;
  margin-top: -1rpx;
  position: relative;
}
.bag-line {
  position: absolute;
  width: 28rpx;
  height: 1.5rpx;
  background: #9C9385;
  bottom: 14rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 我：方形印章（外方内方） */
.ic-me { display: flex; align-items: center; justify-content: center; }
.seal-out {
  position: absolute;
  width: 36rpx; height: 36rpx;
  border: 1.5rpx solid #9C9385;
  border-radius: 4rpx;
}
.seal-in {
  position: absolute;
  width: 16rpx; height: 16rpx;
  border: 1.5rpx solid #9C9385;
  border-radius: 2rpx;
}

.tab-label {
  font-family: "Songti SC", "STSong", serif;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #9C9385;
  line-height: 1.2;
}
.tab--on .tab-label {
  color: #2B2B2B;
  font-weight: 600;
}

.badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: #B85B47;
  color: #FBF7EE;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  font-family: "PingFang SC", sans-serif;
  box-shadow: 0 2rpx 6rpx rgba(184,91,71,0.3);
}
