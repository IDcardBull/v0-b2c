/* 悬浮玻璃胶囊 TabBar */
.tabbar-wrap {
  position: fixed;
  left: 0; right: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  justify-content: center;
  pointer-events: auto;
  padding: 0 0 env(safe-area-inset-bottom);
  background: var(--color-paper);
  box-shadow: 0 -1rpx 0 var(--color-line);
  transform: translateY(0);
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.tabbar--hidden {
  transform: translateY(160%);
  pointer-events: none;
}
.tabbar {
  position: relative;
  width: 100%;
  max-width: 100%;
  pointer-events: auto;
}
.tabbar-bg {
  position: absolute;
  inset: 0;
  border-radius: 0;
  background: transparent;
}

.tabbar-row {
  position: relative;
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  padding: 14rpx 8rpx 12rpx;
}

.tab {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 4rpx 0;
  text-align: center;
  transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.tab:active { transform: scale(0.9); }

.tab-glyph {
  font-size: 44rpx;
  line-height: 1;
  color: var(--color-ink-faint);
  transition: color 0.25s ease, transform 0.25s ease;
}
.tab--on .tab-glyph {
  color: var(--color-ink);
  transform: scale(1.08);
}
.tab-icon {
  width: 44rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ic {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

/* —— 通用细线条颜色 —— */
.ic-home-roof, .ic-home-base,
.ic-cat-l,
.ic-bag-handle, .ic-bag-body,
.ic-me-head, .ic-me-body {
  background: var(--color-ink-faint);
  border-color: var(--color-ink-faint);
  transition: all 0.25s ease;
}
.tab--on .ic-home-roof,
.tab--on .ic-home-base,
.tab--on .ic-cat-l,
.tab--on .ic-bag-handle,
.tab--on .ic-bag-body,
.tab--on .ic-me-head,
.tab--on .ic-me-body {
  background: var(--color-ink);
  border-color: var(--color-ink);
}

/* 首页 · 屋顶 */
.ic-home {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.ic-home-roof {
  width: 0; height: 0;
  background: transparent !important;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 14rpx solid var(--color-ink-faint);
  margin-bottom: -1rpx;
}
.tab--on .ic-home-roof { border-bottom-color: var(--color-ink); }
.ic-home-base {
  width: 24rpx;
  height: 16rpx;
  background: transparent !important;
  border: 1.2rpx solid var(--color-ink-faint);
  border-top: none;
}
.tab--on .ic-home-base { border-color: var(--color-ink); }

/* 分类 · 三横线 */
.ic-cat {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6rpx 0;
}
.ic-cat-l {
  width: 100%;
  height: 1.2rpx;
}
.ic-cat-l:nth-child(2) { width: 70%; }

/* 购物袋 */
.ic-bag {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.ic-bag-handle {
  width: 14rpx;
  height: 8rpx;
  background: transparent !important;
  border: 1.2rpx solid var(--color-ink-faint);
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
}
.tab--on .ic-bag-handle { border-color: var(--color-ink); }
.ic-bag-body {
  width: 26rpx;
  height: 22rpx;
  background: transparent !important;
  border: 1.2rpx solid var(--color-ink-faint);
  border-radius: 2rpx 2rpx 4rpx 4rpx;
  margin-top: -1rpx;
}
.tab--on .ic-bag-body { border-color: var(--color-ink); }

/* 我 */
.ic-me {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}
.ic-me-head {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: transparent !important;
  border: 1.2rpx solid var(--color-ink-faint);
}
.tab--on .ic-me-head { border-color: var(--color-ink); }
.ic-me-body {
  width: 24rpx;
  height: 12rpx;
  border-radius: 12rpx 12rpx 0 0;
  background: transparent !important;
  border: 1.2rpx solid var(--color-ink-faint);
  border-bottom: none;
}
.tab--on .ic-me-body { border-color: var(--color-ink); }

.tab-label {
  font-family: "Songti SC", "STSong", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  width: 100%;
  text-align: center;
  line-height: 1.2;
  transition: all 0.25s ease;
}
.tab--on .tab-label {
  color: var(--color-ink);
  font-weight: 600;
  letter-spacing: 3rpx;
}

.badge {
  position: absolute;
  top: -2rpx;
  right: 50%;
  transform: translateX(40rpx);
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: var(--color-ink);
  color: #F6F1E6;
  font-size: 18rpx;
  font-family: "PingFang SC", sans-serif;
  line-height: 28rpx;
  text-align: center;
  letter-spacing: 0;
  box-shadow: 0 2rpx 8rpx rgba(58, 58, 58, 0.25);
}

/* 仅图标模式 */
.tab-label { display: none !important; }
.tab-icon { width: 56rpx; height: 56rpx; }
.ic { width: 44rpx; height: 44rpx; }
