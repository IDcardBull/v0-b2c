.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  transform: translateY(0);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.tabbar--hidden {
  transform: translateY(120%);
  pointer-events: none;
}

.tabbar-bg {
  position: absolute;
  inset: 0;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-top: 1rpx solid rgba(58, 58, 58, 0.05);
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.04);
}

.tabbar-row {
  position: relative;
  display: flex;
  align-items: stretch;
  justify-content: space-around;
  padding: 20rpx 0 24rpx;
}

.tab {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 10rpx 0;
  transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.tab:active {
  transform: scale(0.88);
}

.tab-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-ink-faint);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab--on .dot {
  background: var(--color-celadon-deep);
  width: 14rpx;
  height: 14rpx;
  box-shadow: 0 0 12rpx rgba(138, 175, 166, 0.5);
}

.tab-label {
  font-family: "Songti SC", "STSong", serif;
  font-size: 22rpx;
  letter-spacing: 5rpx;
  color: var(--color-ink-faint);
  padding-left: 5rpx;
  transition: all 0.25s ease;
}

.tab--on .tab-label {
  color: var(--color-ink);
  font-weight: 600;
  letter-spacing: 7rpx;
}

.badge {
  position: absolute;
  top: 2rpx;
  right: 50%;
  transform: translateX(44rpx);
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 15rpx;
  background: var(--color-celadon-deep);
  color: #fff;
  font-size: 18rpx;
  font-family: "PingFang SC", sans-serif;
  line-height: 30rpx;
  text-align: center;
  letter-spacing: 0;
  box-shadow: 0 2rpx 8rpx rgba(138, 175, 166, 0.4);
  animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: translateX(44rpx) scale(0.5);
  }
  to {
    opacity: 1;
    transform: translateX(44rpx) scale(1);
  }
}
