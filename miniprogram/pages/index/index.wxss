.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* ============ 顶栏 · 透明克制 ============ */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 30;
  background: rgba(239, 232, 220, 0.85);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.brand { display: flex; align-items: baseline; gap: 14rpx; }
.brand-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.brand-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: var(--color-ink-faint);
}
.search-trigger { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.mag-icon { position: relative; width: 28rpx; height: 28rpx; }
.mag-circle { width: 22rpx; height: 22rpx; border: 1.2rpx solid var(--color-ink); border-radius: 50%; }
.mag-stick { position: absolute; right: 0; bottom: 0; width: 10rpx; height: 1.2rpx; background: var(--color-ink); transform: rotate(45deg); transform-origin: right center; }

/* ============ Hero · 顶格 4:3 轮播 ============ */
.hero {
  position: relative;
  width: 100%;
  background: var(--color-card);
}
.hero-swiper {
  width: 100%;
  height: 75vw; /* 4:3 比例 */
}
.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* ============ 分类 · 圆形横滑 ============ */
.cats-section {
  padding: 48rpx 0 24rpx;
}
.cats-scroll {
  width: 100%;
  white-space: nowrap;
}
.cats-row {
  display: inline-flex;
  align-items: flex-start;
  gap: 36rpx;
  padding: 8rpx 40rpx 16rpx;
}
.cat-circle {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  width: 132rpx;
  transition: transform 0.2s ease;
}
.cat-circle:active { transform: scale(0.94); }
.cat-circle-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-paper), var(--color-card));
  border: 1rpx solid rgba(58,58,58,0.08);
  box-shadow: 0 4rpx 14rpx rgba(58,58,58,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.cat-icon {
  width: 100%;
  height: 100%;
}
.cat-circle-char {
  font-family: "Songti SC", serif;
  font-size: 44rpx;
  color: var(--color-ink);
  letter-spacing: 0;
}
.cat-circle-name {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
  text-align: center;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ============ 实体店引流 · 寻访线下空间 ============ */
.storefront {
  padding: 48rpx 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}
.storefront-frame {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #1a1a1a;
}
.storefront-img { width: 100%; height: 100%; display: block; }
.storefront-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 8rpx 0 0;
}
.sf-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 500;
}

/* ============ 章节分隔 · 臻选 ============ */
.section-break {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 64rpx 40rpx 40rpx;
}
.break-cn {
  font-family: "Songti SC", serif;
  font-size: 44rpx;
  letter-spacing: 16rpx;
  padding-left: 16rpx;
  color: var(--color-ink);
  font-weight: 500;
}

/* ============ 画廊 · 错落布局 ============ */
.gallery {
  display: flex;
  flex-wrap: wrap;
  padding: 0 40rpx;
  gap: 24rpx 24rpx;
}
.g-card {
  width: 100%;
  display: flex;
  flex-direction: column;
  transition: opacity 0.25s ease;
}
.g-card:active { opacity: 0.78; }
.g-frame {
  width: 100%;
  overflow: hidden;
  background: var(--color-card);
  border-radius: 8rpx;
}
.g-swiper { width: 100%; height: 100%; }
.g-img { width: 100%; height: 100%; display: block; }

.g-card:nth-child(3n+1) { width: 100%; }
.g-card:nth-child(3n+1) .g-frame { height: 880rpx; }
.g-card:nth-child(3n+2),
.g-card:nth-child(3n) { width: calc(50% - 12rpx); }
.g-card:nth-child(3n+2) .g-frame,
.g-card:nth-child(3n) .g-frame { height: 540rpx; }

/* 卡片信息 */
.g-meta {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 18rpx 4rpx 4rpx;
  gap: 16rpx;
}
.g-meta-left { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.g-title {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.g-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.g-price {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: var(--color-ink-faint);
  margin-top: 4rpx;
  font-weight: 300;
}
.g-add {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(58,58,58,0.35);
  flex-shrink: 0;
}
.g-add-h, .g-add-v {
  position: absolute;
  background: var(--color-ink);
  top: 50%; left: 50%;
}
.g-add-h { width: 16rpx; height: 1rpx; transform: translate(-50%, -50%); }
.g-add-v { width: 1rpx; height: 16rpx; transform: translate(-50%, -50%); }
