.page {
  min-height: 100vh;
  background: var(--color-bg);
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* 导航 */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.78);
  backdrop-filter: blur(20rpx);
}
.navbar-inner {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 40rpx;
  gap: 10rpx;
}
.brand {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.brand-cn {
  font-family: "Songti SC", serif;
  font-size: 34rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
}
.brand-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
}

/* 搜索：透明背景 */
.search {
  display: none; /* 首屏隐藏，首页以品牌为主；保留组件备用 */
}

/* 画报 */
.hero {
  position: relative;
  margin: 24rpx 32rpx 0;
  height: 840rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #ddd;
}
.hero-img {
  width: 100%;
  height: 100%;
}
.hero-swiper {
  width: 100%;
  height: 100%;
}
.hero-paginator {
  position: absolute;
  bottom: 28rpx;
  left: 52rpx;
  display: flex;
  gap: 10rpx;
  z-index: 3;
}
.hp-bar {
  width: 28rpx;
  height: 2rpx;
  background: rgba(58, 58, 58, 0.25);
}
.hp-bar--on {
  width: 56rpx;
  background: var(--color-ink);
}
.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(239, 232, 220, 0) 50%, rgba(239, 232, 220, 0.55) 100%);
}
.hero-copy {
  position: absolute;
  top: 60rpx;
  right: 52rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}
.hero-vertical {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  writing-mode: vertical-rl;
}
.hero-vertical text {
  font-family: "Songti SC", serif;
  font-size: 44rpx;
  color: var(--color-ink);
  letter-spacing: 8rpx;
}
.hero-sub {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding-top: 10rpx;
}
.hero-line {
  width: 1rpx;
  height: 90rpx;
  background: rgba(58, 58, 58, 0.35);
}
.hero-sub text:last-child {
  writing-mode: vertical-rl;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
}
.hero-index {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.dot-sm {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: var(--color-ink-faint);
}

/* 分类 */
.cats {
  padding: 60rpx 40rpx 20rpx;
}
.section-title {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 36rpx;
}
.section-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 10rpx;
  color: var(--color-ink);
}
.section-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
}
.cats-row {
  display: flex;
  justify-content: space-between;
}
.cat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(58, 58, 58, 0.35);
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--color-celadon);
  opacity: 0.92;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cat-cn {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
}
.cat-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}

/* 瀑布流 */
.grid {
  padding: 0 32rpx;
  display: flex;
  gap: 16rpx;
}
.col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}
.spacer {
  height: 60rpx;
}
.card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.card-img {
  width: 100%;
  background: var(--color-paper);
  border-radius: 4rpx;
}
.card-meta {
  padding: 0 6rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}
.card-title {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
}
.seal {
  flex-shrink: 0;
  font-family: "Songti SC", serif;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  padding: 2rpx 10rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.18);
}
.card-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}
.card-price {
  font-size: 26rpx;
  padding-top: 4rpx;
}

/* 结尾 */
.end-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0 40rpx;
}
.end-seal {
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  color: var(--color-ink);
}
.end-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
