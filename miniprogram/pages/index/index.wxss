.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* ============ 顶栏 ============ */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 30;
  background: rgba(239, 232, 220, 0.85);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
}
.navbar-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 36rpx;
}
.brand-title {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-family: "Songti SC", "STSong", serif;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--color-ink);
}
.search-trigger { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.mag-icon { position: relative; width: 28rpx; height: 28rpx; }
.mag-circle { width: 22rpx; height: 22rpx; border: 1.2rpx solid var(--color-ink); border-radius: 50%; }
.mag-stick { position: absolute; right: 0; bottom: 0; width: 10rpx; height: 1.2rpx; background: var(--color-ink); transform: rotate(45deg); transform-origin: right center; }

/* ============ Hero 卡片 ============ */
.hero-card {
  position: relative;
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(58,58,58,0.12);
  background: #1a1a1a;
}
.hero-swiper {
  width: 100%;
  height: calc((100vw - 64rpx) * 0.75); /* 4:3 比例（扣除两侧 32rpx margin） */
}
.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}
.hero-overlay {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  padding: 80rpx 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.25) 60%, transparent 100%);
  pointer-events: none;
}
.hero-title {
  font-family: "STXingkai", "STKaiti", "Kaiti SC", "KaiTi", cursive;
  font-size: 84rpx;
  letter-spacing: 18rpx;
  color: #fff;
  font-weight: 400;
  font-style: italic;
  padding-left: 18rpx;
  text-shadow: 0 4rpx 18rpx rgba(0,0,0,0.55), 0 1rpx 2rpx rgba(0,0,0,0.4);
}
.hero-sub {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  color: rgba(255,255,255,0.92);
  padding-left: 6rpx;
}
.hero-tag {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: rgba(255,255,255,0.78);
  margin-top: 4rpx;
}

/* ============ 分类 4 卡 ============ */
.cat-grid-wrap {
  margin: 36rpx 32rpx 0;
  background: #f3ece0;
  border-radius: 22rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(58,58,58,0.05);
}
.cat-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}
.cat-tile {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  transition: transform 0.2s ease;
}
.cat-tile:active { transform: scale(0.94); }
.cat-tile-inner {
  width: 110rpx;
  height: 110rpx;
  border-radius: 18rpx;
  background: linear-gradient(155deg, #f8f1e1 0%, #ede2cc 100%);
  box-shadow:
    inset 0 1rpx 2rpx rgba(255,255,255,0.7),
    0 2rpx 8rpx rgba(120,90,40,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.cat-tile-icon { width: 70%; height: 70%; }
.cat-tile-char {
  font-family: "Songti SC", "STSong", serif;
  font-size: 48rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.cat-tile-name {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
}

/* ============ 精选清单 标题栏 ============ */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 56rpx 40rpx 28rpx;
}
.section-title {
  font-family: "Songti SC", serif;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  position: relative;
}
.section-title::before {
  content: "";
  position: absolute;
  left: -16rpx;
  top: 8rpx;
  width: 4rpx;
  height: 32rpx;
  background: var(--color-ink);
  border-radius: 2rpx;
}
.section-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.section-more-text {
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}
.section-more-arrow {
  font-size: 24rpx;
  color: var(--color-ink-faint);
}

/* ============ 商品 · 单品横向轮播 ============ */
.gallery-swiper-wrap {
  padding: 4rpx 0 24rpx;
}
.gallery-swiper {
  width: 100%;
  height: 680rpx;
}
.gs-item {
  box-sizing: border-box;
  padding: 16rpx 14rpx 24rpx;
}
.gs-card {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: var(--color-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(58,58,58,0.08);
  transition: transform 0.25s ease, opacity 0.25s ease;
}
.gs-card:active { transform: scale(0.985); opacity: 0.92; }
.gs-frame {
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}
.gs-img { width: 100%; height: 100%; display: block; }
.gs-meta {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 24rpx 28rpx 26rpx;
  gap: 16rpx;
}
.gs-meta-right { display: flex; align-items: flex-end; }
.gs-meta-left { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.gs-title {
  font-family: "Songti SC", "STSong", serif;
  font-size: 36rpx;
  letter-spacing: 2rpx;
  color: #1F1F1F;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.gs-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.gs-price {
  font-family: "PingFang SC", sans-serif;
  font-size: 34rpx;
  letter-spacing: 0;
  color: #1F1F1F;
  font-weight: 700;
}
.gs-add {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(58,58,58,0.35);
  flex-shrink: 0;
}
.gs-add-h, .gs-add-v {
  position: absolute;
  background: var(--color-ink);
  top: 50%; left: 50%;
}
.gs-add-h { width: 16rpx; height: 1rpx; transform: translate(-50%, -50%); }
.gs-add-v { width: 1rpx; height: 16rpx; transform: translate(-50%, -50%); }

/* ============ 实体店引流 · 寻访线下空间 ============ */
.storefront {
  margin: 40rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.storefront-frame {
  width: 100%;
  height: 480rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #1a1a1a;
  box-shadow: 0 10rpx 28rpx rgba(58,58,58,0.10);
}
.storefront-img { width: 100%; height: 100%; display: block; }
.storefront-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 4rpx 0 0;
}
.sf-cn {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 12rpx;
  color: var(--color-ink-soft);
  font-weight: 400;
}


/* ============ 精选好物 · 双列瀑布流 ============ */
.waterfall {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 24rpx 24rpx;
}
.wf-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-width: 0;
}
.wf-card {
  background: var(--color-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 18rpx rgba(58,58,58,0.06);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.wf-card:active { transform: scale(0.98); opacity: 0.9; }
.wf-img {
  width: 100%;
  display: block;
  background: #f5f1ea;
}
.wf-meta {
  padding: 12rpx 18rpx 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  align-items: stretch;
}
.wf-title {
  font-family: "Songti SC", "STSong", serif;
  font-size: 28rpx;
  color: #1F1F1F;
  letter-spacing: 1rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.wf-price-row { display: flex; justify-content: space-between; align-items: center; }
.wf-price {
  font-family: "PingFang SC", sans-serif;
  font-size: 28rpx;
  color: #1F1F1F;
  letter-spacing: 0;
  font-weight: 700;
  text-align: right;
}
.wf-add { width: 40rpx; height: 40rpx; }
.wf-add .gs-add-h { width: 14rpx; }
.wf-add .gs-add-v { height: 14rpx; }
