.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* ============ 顶栏 · 透明克制 ============ */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 30;
  background: transparent;
  pointer-events: none;
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  pointer-events: auto;
}
.brand {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.brand-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.brand-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: var(--color-ink-faint);
}
.search-trigger {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
}
.mag-icon {
  position: relative;
  width: 28rpx; height: 28rpx;
}
.mag-circle {
  width: 22rpx; height: 22rpx;
  border: 1.2rpx solid var(--color-ink);
  border-radius: 50%;
}
.mag-stick {
  position: absolute;
  right: 0; bottom: 0;
  width: 10rpx; height: 1.2rpx;
  background: var(--color-ink);
  transform: rotate(45deg);
  transform-origin: right center;
}

/* ============ Hero · 全屏沉浸画报 ============ */
.hero {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: var(--color-card);
}
.hero-swiper, .hero-img {
  width: 100%; height: 100%;
}
.hero-img {
  display: block;
}
.hero-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 55%;
  background: linear-gradient(
    180deg,
    rgba(239,232,220,0) 0%,
    rgba(239,232,220,0.05) 30%,
    rgba(239,232,220,0.45) 75%,
    rgba(239,232,220,0.85) 100%
  );
  pointer-events: none;
}

.hero-title-block {
  position: absolute;
  left: 56rpx;
  bottom: 140rpx;
  display: flex;
  align-items: flex-end;
  gap: 28rpx;
  animation: fadeInUp 0.9s var(--ease-out) 0.2s both;
}
.hero-vertical {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.hero-vertical text {
  font-family: "Songti SC", "STSong", serif;
  font-size: 76rpx;
  line-height: 0.95;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  font-weight: 400;
}
.hero-rule {
  width: 1rpx;
  height: 120rpx;
  background: var(--color-ink);
  opacity: 0.5;
  margin: 0 6rpx 12rpx;
}
.hero-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-bottom: 14rpx;
}
.hero-meta-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
}
.hero-meta-vol {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  font-style: italic;
}

.hero-issue {
  position: absolute;
  right: 56rpx;
  bottom: 140rpx;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  font-family: "PingFang SC", sans-serif;
  color: var(--color-ink);
  animation: fadeIn 1s var(--ease-out) 0.4s both;
}
.hero-issue text:first-child {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.hero-issue-num {
  font-family: "Songti SC", serif;
  font-size: 56rpx;
  letter-spacing: 2rpx;
  font-weight: 300;
  line-height: 1;
}

.hero-paginator {
  position: absolute;
  left: 56rpx;
  bottom: 80rpx;
  display: flex;
  gap: 10rpx;
  z-index: 4;
}
.hp-bar {
  width: 12rpx;
  height: 1rpx;
  background: rgba(58,58,58,0.35);
  transition: width var(--duration-normal) var(--ease-out), background var(--duration-normal);
}
.hp-bar--on {
  width: 56rpx;
  background: var(--color-ink);
}

/* ============ Section · 通用 kicker 标签 ============ */
.kicker {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 0 40rpx;
  margin-bottom: 48rpx;
}
.kicker-line {
  width: 36rpx;
  height: 1rpx;
  background: var(--color-ink);
}
.kicker-text {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
}
.kicker-cn {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink-soft);
}

/* ============ 品类 · 横向文字导航 ============ */
.cats-section {
  padding: 120rpx 0 40rpx;
}
.cats-scroll {
  width: 100%;
  white-space: nowrap;
}
.cats-row {
  display: inline-flex;
  align-items: center;
  gap: 56rpx;
  padding: 0 48rpx 8rpx;
}
.cat-item {
  position: relative;
  padding: 12rpx 0 18rpx;
  transition: color 0.2s ease;
}
.cat-text {
  font-family: "Songti SC", serif;
  font-size: 32rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-faint);
  font-weight: 400;
}
.cat-item--on .cat-text {
  color: var(--color-ink);
  font-weight: 600;
}
.cat-item--on::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 24rpx;
  height: 1.5rpx;
  background: var(--color-ink);
}

/* ============ 章节分隔 · 印章式 ============ */
.section-break {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 96rpx 40rpx 80rpx;
}
.break-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
}
.break-cn {
  font-family: "Songti SC", serif;
  font-size: 48rpx;
  letter-spacing: 24rpx;
  padding-left: 24rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.break-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  font-style: italic;
  margin-top: 8rpx;
}

/* ============ 画廊 · 错落策展布局 ============ */
.gallery {
  display: flex;
  flex-wrap: wrap;
  padding: 0 40rpx;
  gap: 24rpx 24rpx;
}
.g-card {
  width: 100%;
  display: flex;
  flex-direction: column;
  transition: opacity 0.25s ease;
}
.g-card:active { opacity: 0.78; }
.g-frame {
  width: 100%;
  overflow: hidden;
  background: var(--color-card);
}
.g-img {
  width: 100%;
  height: 100%;
  display: block;
  transition: transform 0.6s var(--ease-out);
}

/* 错落规则：3n+1 通栏大图，3n+2 / 3n+3 两张竖图同行 */
.g-card:nth-child(3n+1) { width: 100%; }
.g-card:nth-child(3n+1) .g-frame { height: 880rpx; }

.g-card:nth-child(3n+2),
.g-card:nth-child(3n) {
  width: calc(50% - 12rpx);
}
.g-card:nth-child(3n+2) .g-frame,
.g-card:nth-child(3n) .g-frame {
  height: 720rpx;
}

/* 卡片信息 */
.g-meta {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 24rpx 4rpx 8rpx;
  gap: 16rpx;
}
.g-meta-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.g-title {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.g-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.g-price {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: var(--color-ink-faint);
  margin-top: 6rpx;
  font-weight: 300;
}

/* 极简加号按钮 —— 1rpx 边框圆形 */
.g-add {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(58,58,58,0.35);
  flex-shrink: 0;
  transition: all 0.25s ease;
}
.g-add-h, .g-add-v {
  position: absolute;
  background: var(--color-ink);
  top: 50%; left: 50%;
}
.g-add-h {
  width: 16rpx;
  height: 1rpx;
  transform: translate(-50%, -50%);
}
.g-add-v {
  width: 1rpx;
  height: 16rpx;
  transform: translate(-50%, -50%);
}

/* ============ 结尾 ============ */
.end-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 140rpx 0 60rpx;
}
.end-seal {
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid var(--color-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  color: var(--color-ink);
}
.end-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-faint);
}
