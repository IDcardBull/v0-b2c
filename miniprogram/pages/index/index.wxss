.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* ============ 顶栏 · 透明克制 ============ */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 30;
  background: rgba(239, 232, 220, 0.85);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.brand { display: flex; align-items: baseline; gap: 14rpx; }
.brand-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.brand-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: var(--color-ink-faint);
}
.search-trigger { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; }
.mag-icon { position: relative; width: 28rpx; height: 28rpx; }
.mag-circle { width: 22rpx; height: 22rpx; border: 1.2rpx solid var(--color-ink); border-radius: 50%; }
.mag-stick { position: absolute; right: 0; bottom: 0; width: 10rpx; height: 1.2rpx; background: var(--color-ink); transform: rotate(45deg); transform-origin: right center; }

/* ============ Hero · 顶格 3:4 轮播 ============ */
.hero {
  position: relative;
  width: 100%;
  background: var(--color-card);
}
.hero-swiper {
  width: 100%;
  height: 133.33vw; /* 3:4 比例（竖向） */
}
.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* ============ 分类 · 精致圆形横滑 ============ */
.cats-section {
  padding: 36rpx 0 12rpx;
}
.cats-scroll {
  width: 100%;
  white-space: nowrap;
}
.cats-row {
  display: inline-flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 6rpx 44rpx 14rpx;
}
.cat-circle {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 96rpx;
  transition: transform 0.25s ease;
}
.cat-circle:active { transform: scale(0.92); }
.cat-circle-inner {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 28%, #fbf6ec 0%, #efe5d2 70%, #e6d9bf 100%);
  box-shadow:
    inset 0 1rpx 2rpx rgba(255,255,255,0.7),
    inset 0 -2rpx 6rpx rgba(120,90,40,0.06),
    0 2rpx 8rpx rgba(58,58,58,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.cat-circle-inner::after {
  content: "";
  position: absolute;
  inset: 4rpx;
  border-radius: 50%;
  border: 0.6rpx solid rgba(120,90,40,0.18);
  pointer-events: none;
}
.cat-icon {
  width: 100%;
  height: 100%;
}
.cat-circle-char {
  font-family: "Songti SC", "STSong", serif;
  font-size: 32rpx;
  color: var(--color-ink);
  letter-spacing: 0;
  font-weight: 500;
}
.cat-circle-name {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-soft);
  text-align: center;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ============ 实体店引流 · 寻访线下空间 ============ */
.storefront {
  padding: 40rpx 40rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.storefront-frame {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #1a1a1a;
}
.storefront-img { width: 100%; height: 100%; display: block; }
.storefront-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 6rpx 0 0;
}
.sf-cn {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 12rpx;
  color: var(--color-ink-soft);
  font-weight: 400;
}

/* ============ 章节分隔 · 臻选（柔和过渡） ============ */
.section-break {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 36rpx 40rpx 28rpx;
  position: relative;
}
.section-break::before {
  content: "";
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 1rpx;
  height: 28rpx;
  background: linear-gradient(to bottom, transparent, rgba(58,58,58,0.25));
}
.break-cn {
  font-family: "Songti SC", serif;
  font-size: 38rpx;
  letter-spacing: 14rpx;
  padding-left: 14rpx;
  color: var(--color-ink);
  font-weight: 500;
}

/* ============ 商品 · 单品横向轮播 ============ */
.gallery-swiper-wrap {
  padding: 8rpx 0 24rpx;
}
.gallery-swiper {
  width: 100%;
  height: 920rpx;
}
.gs-item {
  box-sizing: border-box;
  padding: 16rpx 14rpx 24rpx;
}
.gs-card {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: var(--color-card);
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(58,58,58,0.08);
  transition: transform 0.25s ease, opacity 0.25s ease;
}
.gs-card:active { transform: scale(0.985); opacity: 0.92; }
.gs-frame {
  width: 100%;
  height: 760rpx;
  overflow: hidden;
}
.gs-img { width: 100%; height: 100%; display: block; }
.gs-meta {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 22rpx 26rpx 22rpx;
  gap: 16rpx;
}
.gs-meta-left { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.gs-title {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.gs-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.gs-price {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: var(--color-ink-faint);
  margin-top: 4rpx;
  font-weight: 300;
}
.gs-add {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(58,58,58,0.35);
  flex-shrink: 0;
}
.gs-add-h, .gs-add-v {
  position: absolute;
  background: var(--color-ink);
  top: 50%; left: 50%;
}
.gs-add-h { width: 16rpx; height: 1rpx; transform: translate(-50%, -50%); }
.gs-add-v { width: 1rpx; height: 16rpx; transform: translate(-50%, -50%); }
