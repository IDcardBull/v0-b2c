<view class="page">
  <!-- 自定义导航：状态栏占位 + 透明搜索条 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <view class="brand">
        <text class="brand-cn">央茗</text>
        <text class="brand-en">YANGMING · CERAMICS</text>
      </view>
      <view class="search" bindtap="onSearch">
        <view class="search-icon">
          <view class="circle"></view>
          <view class="stick"></view>
        </view>
        <text class="search-ph">寻一器 · 青釉 / 花器 / 香炉</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <!-- 画报 -->
    <view class="hero">
      <image class="hero-img" src="/images/hero-celadon.jpg" mode="aspectFill"></image>
      <view class="hero-mask"></view>
      <view class="hero-copy">
        <view class="hero-vertical">
          <text>青</text><text>釉</text><text>映</text><text>月</text>
        </view>
        <view class="hero-sub">
          <text class="hero-line"></text>
          <text>一器一境 · 器以载道</text>
        </view>
      </view>
      <view class="hero-index">
        <text>2026 · 春</text>
        <text class="dot-sm"></text>
        <text>第 柒 辑</text>
      </view>
    </view>

    <!-- 分类圆环 -->
    <view class="cats">
      <view class="section-title">
        <text class="section-cn">品类</text>
        <text class="section-en">CATEGORY</text>
      </view>
      <view class="cats-row">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="cat"
          data-id="{{item.id}}"
          bindtap="goCategory"
        >
          <view class="ring">
            <view class="ring-inner">
              <text class="cat-cn">{{item.name}}</text>
            </view>
          </view>
          <text class="cat-en">{{item.sub}}</text>
        </view>
      </view>
    </view>

    <!-- 印章分隔 -->
    <view class="divider-seal"><text>臻 · 选</text></view>

    <!-- 瀑布流（双列错落） -->
    <view class="grid">
      <view class="col">
        <view
          wx:for="{{left}}"
          wx:key="id"
          class="card"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >
          <image class="card-img" src="{{item.cover}}" mode="aspectFill" style="height: {{item.h}}rpx;"></image>
          <view class="card-meta">
            <view class="card-title-row">
              <text class="card-title">{{item.name}}</text>
              <text wx:if="{{item.tag}}" class="seal">{{item.tag}}</text>
            </view>
            <text class="card-sub">{{item.sub}}</text>
            <view class="card-price price">
              <text class="unit">¥</text>{{item.price}}
            </view>
          </view>
        </view>
      </view>
      <view class="col">
        <view class="spacer"></view>
        <view
          wx:for="{{right}}"
          wx:key="id"
          class="card"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >
          <image class="card-img" src="{{item.cover}}" mode="aspectFill" style="height: {{item.h}}rpx;"></image>
          <view class="card-meta">
            <view class="card-title-row">
              <text class="card-title">{{item.name}}</text>
              <text wx:if="{{item.tag}}" class="seal">{{item.tag}}</text>
            </view>
            <text class="card-sub">{{item.sub}}</text>
            <view class="card-price price">
              <text class="unit">¥</text>{{item.price}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="end-mark">
      <text class="end-seal">止</text>
      <text class="end-sub">THE END · 止於此</text>
    </view>

    <view style="height: 180rpx;"></view>
  </scroll-view>
</view>
