<view class="page">
  <!-- 顶栏：极简标题 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      
      <view class="search-trigger" bindtap="onSearch">
        <view class="mag-icon">
          <view class="mag-circle"></view>
          <view class="mag-stick"></view>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" enhanced show-scrollbar="{{false}}" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <!-- Hero · 圆角大图 + 文字叠层 -->
    <view class="hero-card">
      <swiper
        class="hero-swiper"
        indicator-dots="{{false}}"
        autoplay
        circular
        interval="5000"
        duration="700"
        current="{{bannerIdx}}"
        bindchange="onBannerChange"
      >
        <block wx:if="{{banners.length > 0}}">
          <swiper-item wx:for="{{banners}}" wx:key="id">
            <image class="hero-img" src="{{item.image}}" mode="aspectFill" data-link="{{item.link}}" bindtap="onBannerTap"></image>
          </swiper-item>
        </block>
        <block wx:else>
          <swiper-item><image class="hero-img" src="/images/storefront.png" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-jinkui-01.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-huakou-01.jpg" mode="aspectFill"></image></swiper-item>
        </block>
      </swiper>
      
    </view>

    <!-- 分类 · 4 件套米色方卡 -->
    <view class="cat-grid-wrap">
      <view class="cat-grid">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="cat-tile"
          data-id="{{item.id}}"
          bindtap="goCategory"
        >
          <view class="cat-tile-inner">
            <image wx:if="{{item.icon}}" class="cat-tile-icon" src="{{item.icon}}" mode="aspectFit"></image>
            <text wx:else class="cat-tile-char">{{item.name[0]}}</text>
          </view>
          
        </view>
      </view>
    </view>

    <!-- 实体店引流 · 寻访线下空间 -->
    <view class="storefront">
      <view class="storefront-frame">
        <image class="storefront-img" src="/images/storefront.png" mode="aspectFill"></image>
      </view>
      <view class="storefront-meta">
        <text class="sf-cn">寻 访 线 下 空 间</text>
      </view>
    </view>

    <!-- 精选清单 -->
    <view class="section-head">
      <text class="section-title">精选清单</text>
      <view class="section-more" bindtap="goCategory">
        <text class="section-more-text">查看全部</text>
        <text class="section-more-arrow">→</text>
      </view>
    </view>

    <!-- 商品 · 单品横向轮播 -->
    <view class="gallery-swiper-wrap">
      <swiper
        class="gallery-swiper"
        previous-margin="56rpx"
        next-margin="56rpx"
        circular
        autoplay
        interval="5000"
        duration="600"
      >
        <swiper-item wx:for="{{list}}" wx:key="id" class="gs-item">
          <view class="gs-card" data-id="{{item.id}}" bindtap="goDetail">
            <view class="gs-frame">
              <image class="gs-img" src="{{item.image || item.gallery[0]}}" mode="aspectFill"></image>
            </view>
            <view class="gs-meta">
              <view class="gs-meta-left">
                <text class="gs-title">{{item.name}}</text>
              </view>
              <view class="gs-meta-right">
                <text class="gs-price">¥ {{item.price}}</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>


    <!-- 精选好物 · 双列瀑布流 -->
    <view class="section-head">
      <text class="section-title">精选好物</text>
    </view>
    <view class="waterfall">
      <view class="wf-col">
        <view wx:for="{{waterfallLeft}}" wx:key="id" class="wf-card" data-id="{{item.id}}" bindtap="goDetail">
          <image class="wf-img" src="{{item.image || item.gallery[0]}}" mode="widthFix"></image>
          <view class="wf-meta">
            <text class="wf-title">{{item.name}}</text>
            <view class="wf-price-row"><text class="wf-price">¥ {{item.price}}</text></view>
          </view>
        </view>
      </view>
      <view class="wf-col">
        <view wx:for="{{waterfallRight}}" wx:key="id" class="wf-card" data-id="{{item.id}}" bindtap="goDetail">
          <image class="wf-img" src="{{item.image || item.gallery[0]}}" mode="widthFix"></image>
          <view class="wf-meta">
            <text class="wf-title">{{item.name}}</text>
            <view class="wf-price-row"><text class="wf-price">¥ {{item.price}}</text></view>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 240rpx;"></view>
  </scroll-view>
</view>
