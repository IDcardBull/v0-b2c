<view class="page">
  <!-- 顶部：极简透明导航 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <view class="brand">
        <text class="brand-cn">釉见</text>
        <text class="brand-en">YOUJIAN</text>
      </view>
      <view class="search-trigger" bindtap="onSearch">
        <view class="mag-icon">
          <view class="mag-circle"></view>
          <view class="mag-stick"></view>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" enhanced show-scrollbar="{{false}}">
    <!-- Hero —— 全屏沉浸画报 -->
    <view class="hero" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
      <block wx:if="{{banners.length > 0}}">
        <swiper
          class="hero-swiper"
          indicator-dots="{{false}}"
          autoplay
          circular
          interval="4500"
          duration="700"
          current="{{bannerIdx}}"
          bindchange="onBannerChange"
        >
          <swiper-item wx:for="{{banners}}" wx:key="id">
            <image
              class="hero-img"
              src="{{item.image}}"
              mode="aspectFill"
              data-link="{{item.link}}"
              bindtap="onBannerTap"
            ></image>
          </swiper-item>
        </swiper>
      </block>
      <block wx:else>
        <swiper
          class="hero-swiper"
          indicator-dots="{{false}}"
          autoplay
          circular
          interval="4500"
          duration="700"
          current="{{bannerIdx}}"
          bindchange="onBannerChange"
        >
          <swiper-item><image class="hero-img" src="/images/feature-jinkui-01.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-huakou-01.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-jinkui-03.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-huakou-03.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-jinkui-05.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-huakou-05.jpg" mode="aspectFill"></image></swiper-item>
        </swiper>
      </block>

      <view class="hero-fade"></view>

      <!-- 左下竖排标题 —— 占位文案 -->
      <view class="hero-title-block">
        <view class="hero-vertical">
          <text>青</text><text>釉</text><text>映</text><text>月</text>
        </view>
        <view class="hero-rule"></view>
        <view class="hero-meta">
          <text class="hero-meta-en">CERAMICS EDIT</text>
          <text class="hero-meta-vol">Vol. 07 · Spring 2026</text>
        </view>
      </view>

      <!-- 右下角刊号 -->
      <view class="hero-issue">
        <text>NO.</text>
        <text class="hero-issue-num">007</text>
      </view>

      <!-- 极细横线分页器 -->
      <view class="hero-paginator" wx:if="{{banners.length > 1}}">
        <view
          wx:for="{{banners}}"
          wx:key="id"
          wx:for-index="bi"
          class="hp-bar {{bi === bannerIdx ? 'hp-bar--on' : ''}}"
        ></view>
      </view>
    </view>

    <!-- 实体店引流 —— 寻访线下空间 -->
    <view class="storefront">
      <view class="storefront-kicker">
        <text class="sf-en">VISIT · OFFLINE</text>
        <text class="sf-line"></text>
      </view>
      <view class="storefront-frame">
        <image class="storefront-img" src="/images/storefront.png" mode="aspectFill"></image>
      </view>
      <view class="storefront-meta">
        <text class="sf-cn">寻 访 线 下 空 间</text>
        <text class="sf-sub">Youjian Ceramics Atelier · 釉见陶集</text>
      </view>
    </view>

    <!-- 品类 —— 杂志感横向文字滑动 -->
    <view class="cats-section">
      <view class="kicker">
        <text class="kicker-line"></text>
        <text class="kicker-text">EDIT · 01</text>
        <text class="kicker-cn">品类</text>
      </view>
      <scroll-view scroll-x class="cats-scroll" enhanced show-scrollbar="{{false}}">
        <view class="cats-row">
          <view
            wx:for="{{categories}}"
            wx:key="id"
            wx:for-index="ci"
            class="cat-item {{ci === 0 ? 'cat-item--on' : ''}}"
            data-id="{{item.id}}"
            bindtap="goCategory"
          >
            <text class="cat-text">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 印章分隔 -->
    <view class="section-break">
      <text class="break-en">SELECTED · 02</text>
      <text class="break-cn">臻 · 选</text>
      <text class="break-sub">A curated edit of contemporary ceramics</text>
    </view>

    <!-- 商品 —— 画廊策展式错落布局 -->
    <view class="gallery">
      <view
        wx:for="{{list}}"
        wx:key="id"
        class="g-card"
        data-id="{{item.id}}"
        bindtap="goDetail"
      >
        <view class="g-frame">
          <image class="g-img" src="{{item.mainImage}}" mode="aspectFill"></image>
        </view>
        <view class="g-meta">
          <view class="g-meta-left">
            <text class="g-title">{{item.name}}</text>
            <text class="g-sub">{{item.sub}}</text>
            <text class="g-price">¥ {{item.price}}</text>
          </view>
          <view class="g-add">
            <view class="g-add-h"></view>
            <view class="g-add-v"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="end-mark">
      <text class="end-seal">止</text>
      <text class="end-sub">FIN · 止 於 此</text>
    </view>

    <view style="height: 220rpx;"></view>
  </scroll-view>
</view>
