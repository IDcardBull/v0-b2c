<view class="page">
  <!-- 顶部：极简透明导航 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <view class="brand">
        <text class="brand-cn">釉见</text>
        <text class="brand-en">YOUJIAN</text>
      </view>
      <view class="search-trigger" bindtap="onSearch">
        <view class="mag-icon">
          <view class="mag-circle"></view>
          <view class="mag-stick"></view>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" enhanced show-scrollbar="{{false}}">
    <!-- Hero —— 顶格 4:3 轮播 -->
    <view class="hero">
      <block wx:if="{{banners.length > 0}}">
        <swiper
          class="hero-swiper"
          indicator-dots="{{true}}"
          indicator-color="rgba(58,58,58,0.3)"
          indicator-active-color="#3a3a3a"
          autoplay
          circular
          interval="4500"
          duration="700"
          current="{{bannerIdx}}"
          bindchange="onBannerChange"
        >
          <swiper-item wx:for="{{banners}}" wx:key="id">
            <image
              class="hero-img"
              src="{{item.image}}"
              mode="aspectFill"
              data-link="{{item.link}}"
              bindtap="onBannerTap"
            ></image>
          </swiper-item>
        </swiper>
      </block>
      <block wx:else>
        <swiper
          class="hero-swiper"
          indicator-dots="{{true}}"
          indicator-color="rgba(58,58,58,0.3)"
          indicator-active-color="#3a3a3a"
          autoplay
          circular
          interval="4500"
          duration="700"
          current="{{bannerIdx}}"
          bindchange="onBannerChange"
        >
          <swiper-item><image class="hero-img" src="/images/feature-jinkui-01.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-huakou-01.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-jinkui-03.jpg" mode="aspectFill"></image></swiper-item>
          <swiper-item><image class="hero-img" src="/images/feature-huakou-03.jpg" mode="aspectFill"></image></swiper-item>
        </swiper>
      </block>
    </view>

    <!-- 分类 · 圆形横向滑动 -->
    <view class="cats-section">
      <scroll-view scroll-x class="cats-scroll" enhanced show-scrollbar="{{false}}">
        <view class="cats-row">
          <view
            wx:for="{{categories}}"
            wx:key="id"
            class="cat-circle"
            data-id="{{item.id}}"
            bindtap="goCategory"
          >
            <view class="cat-circle-inner">
              <image wx:if="{{item.icon || item.image}}" class="cat-icon" src="{{item.icon || item.image}}" mode="aspectFill"></image>
              <text wx:else class="cat-circle-char">{{item.name[0]}}</text>
            </view>
            <text class="cat-circle-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 实体店引流 —— 寻访线下空间 -->
    <view class="storefront">
      <view class="storefront-frame">
        <image class="storefront-img" src="/images/storefront.png" mode="aspectFill"></image>
      </view>
      <view class="storefront-meta">
        <text class="sf-cn">寻 访 线 下 空 间</text>
      </view>
    </view>

    <!-- 章节分隔 -->
    <view class="section-break">
      <text class="break-cn">臻 选</text>
    </view>

    <!-- 商品 —— 单品横向轮播（一件一件） -->
    <view class="gallery-swiper-wrap">
      <swiper
        class="gallery-swiper"
        previous-margin="60rpx"
        next-margin="60rpx"
        circular
        autoplay
        interval="5000"
        duration="600"
      >
        <swiper-item wx:for="{{list}}" wx:key="id" class="gs-item">
          <view class="gs-card" data-id="{{item.id}}" bindtap="goDetail">
            <view class="gs-frame">
              <image class="gs-img" src="{{item.image || item.gallery[0]}}" mode="aspectFill"></image>
            </view>
            <view class="gs-meta">
              <view class="gs-meta-left">
                <text class="gs-title">{{item.name}}</text>
                <text class="gs-sub">{{item.sub}}</text>
                <text class="gs-price">¥ {{item.price}}</text>
              </view>
              <view class="gs-add" catchtap="goDetail" data-id="{{item.id}}">
                <view class="gs-add-h"></view>
                <view class="gs-add-v"></view>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view style="height: 60rpx;"></view>
  </scroll-view>
</view>
