.page { min-height: 100vh; background: #1F2828; color: #ECE4D4; }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 30;
  background: rgba(31, 40, 40, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(184, 207, 200, 0.08);
}
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back { font-size: 56rpx; line-height: 1; width: 64rpx; color: #ECE4D4; }
.page-title { text-align: center; flex: 1; }
.t-cn { font-size: 30rpx; letter-spacing: 8rpx; }
.t-en {
  display: block; margin-top: 4rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx; letter-spacing: 6rpx;
  color: rgba(236, 228, 212, 0.45);
}
.scan-btn {
  width: 64rpx; line-height: 56rpx; text-align: center;
  border: 1rpx solid rgba(184, 207, 200, 0.3);
  color: #B8CFC8; border-radius: 8rpx; font-size: 24rpx;
}

.empty { text-align: center; padding: 200rpx 0; color: rgba(236, 228, 212, 0.4); font-size: 26rpx; }

.hero {
  margin: 32rpx 32rpx 0;
  padding: 24rpx;
  background: rgba(246, 241, 230, 0.04);
  border: 1rpx solid rgba(184, 207, 200, 0.1);
  border-radius: 16rpx;
  display: flex; gap: 24rpx; align-items: center;
}
.cover { width: 160rpx; height: 160rpx; border-radius: 8rpx; flex-shrink: 0; background: rgba(184, 207, 200, 0.08); }
.hero-meta { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.hero-name {
  font-size: 30rpx; letter-spacing: 1rpx; color: #ECE4D4;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.hero-code {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; color: rgba(236, 228, 212, 0.45);
}
.hero-price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 32rpx; color: #B8CFC8;
}
.hero-price .unit { font-size: 20rpx; margin-right: 4rpx; color: rgba(184, 207, 200, 0.7); }

.block { margin-top: 32rpx; padding: 0 32rpx; }
.block-head { padding: 0 8rpx 16rpx; display: flex; align-items: baseline; gap: 16rpx; }
.head-cn { font-size: 26rpx; letter-spacing: 6rpx; color: #ECE4D4; }
.head-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx; letter-spacing: 6rpx;
  color: rgba(236, 228, 212, 0.4);
}

.toggle-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(246, 241, 230, 0.04);
  border: 1rpx solid rgba(184, 207, 200, 0.1);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}
.toggle-text { display: flex; flex-direction: column; gap: 4rpx; }
.toggle-cn { font-size: 28rpx; letter-spacing: 2rpx; color: #ECE4D4; }
.toggle-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; color: rgba(236, 228, 212, 0.5);
}
.toggle-action {
  font-size: 26rpx; letter-spacing: 4rpx;
  color: #B8CFC8;
  padding: 12rpx 24rpx;
  border: 1rpx solid rgba(184, 207, 200, 0.3);
  border-radius: 8rpx;
}

.empty-card {
  padding: 40rpx;
  text-align: center;
  color: rgba(236, 228, 212, 0.5);
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx;
  background: rgba(246, 241, 230, 0.04);
  border: 1rpx solid rgba(184, 207, 200, 0.1);
  border-radius: 16rpx;
}

.sku-card {
  background: rgba(246, 241, 230, 0.04);
  border: 1rpx solid rgba(184, 207, 200, 0.1);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 12rpx;
  display: flex; flex-direction: column; gap: 16rpx;
}
.sku-head {
  display: flex; align-items: center; justify-content: space-between;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed rgba(184, 207, 200, 0.12);
}
.sku-spec { font-size: 28rpx; color: #ECE4D4; letter-spacing: 1rpx; }
.sku-code {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx; color: rgba(236, 228, 212, 0.4);
}

.sku-row {
  display: flex; align-items: center; justify-content: space-between;
  font-family: "PingFang SC", sans-serif;
}
.sku-label { font-size: 24rpx; color: rgba(236, 228, 212, 0.6); letter-spacing: 2rpx; }
.sku-value {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 28rpx; color: #ECE4D4;
}
.sku-value .unit { font-size: 18rpx; margin-right: 4rpx; color: rgba(236, 228, 212, 0.5); }

.stepper {
  display: flex; align-items: center;
  border: 1rpx solid rgba(184, 207, 200, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
}
.step-btn {
  width: 64rpx; height: 56rpx; line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  color: #B8CFC8;
  background: rgba(184, 207, 200, 0.08);
}
.stock-input {
  width: 120rpx; height: 56rpx; line-height: 56rpx;
  text-align: center;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 28rpx;
  color: #ECE4D4;
}

.sku-foot { display: flex; align-items: center; justify-content: space-between; }
.sku-hint {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; color: rgba(236, 228, 212, 0.4);
}
.save-btn {
  padding: 12rpx 28rpx;
  background: #B8CFC8;
  color: #1F2828;
  border-radius: 8rpx;
  font-size: 24rpx; letter-spacing: 4rpx;
}
.save-btn--loading { opacity: 0.6; }

.hint-card {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(232, 195, 111, 0.06);
  border: 1rpx solid rgba(232, 195, 111, 0.18);
  border-radius: 8rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: rgba(232, 195, 111, 0.85);
  letter-spacing: 1rpx;
  line-height: 1.6;
}
