.page { min-height: 100vh; background: #1F2828; color: #ECE4D4; }
.scroll { height: 100vh; box-sizing: border-box; padding-bottom: 200rpx; }

/* ===== navbar ===== */
.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 20;
  background: rgba(31, 40, 40, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(184, 207, 200, 0.08);
}
.navbar-inner {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24rpx;
}
.back {
  width: 64rpx; height: 64rpx; line-height: 56rpx; text-align: center;
  font-size: 56rpx; color: rgba(236, 228, 212, 0.7);
}
.page-title { display: flex; flex-direction: column; align-items: center; gap: 2rpx; }
.t-cn {
  font-family: "Songti SC", "STSong", serif;
  font-size: 32rpx; letter-spacing: 8rpx; color: #ECE4D4;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx; letter-spacing: 4rpx;
  color: rgba(184, 207, 200, 0.55);
}
.nav-add {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(184, 207, 200, 0.15);
  border: 1rpx solid rgba(184, 207, 200, 0.4);
}
.plus { font-size: 36rpx; color: #B8CFC8; line-height: 1; }

/* ===== hero ===== */
.hero {
  padding: 48rpx 40rpx 24rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}
.hero-cn {
  font-family: "Songti SC", "STSong", serif;
  font-size: 52rpx; letter-spacing: 4rpx; color: #ECE4D4;
}
.hero-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx; letter-spacing: 6rpx;
  color: rgba(184, 207, 200, 0.55);
}
.hero-sub {
  margin-top: 8rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx;
  color: rgba(236, 228, 212, 0.55);
}

/* ===== empty ===== */
.empty {
  padding: 120rpx 40rpx;
  display: flex; flex-direction: column; align-items: center; gap: 24rpx;
}
.empty-seal {
  width: 96rpx; height: 96rpx; line-height: 96rpx; text-align: center;
  font-family: "Songti SC", serif; font-size: 44rpx;
  color: rgba(236, 228, 212, 0.4);
  border: 1rpx solid rgba(184, 207, 200, 0.2);
  border-radius: 4rpx;
}
.empty-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx; letter-spacing: 4rpx;
  color: rgba(236, 228, 212, 0.5);
}
.empty-btn {
  margin-top: 16rpx;
  padding: 18rpx 40rpx;
  border: 1rpx solid rgba(184, 207, 200, 0.5);
  border-radius: 8rpx;
  color: #B8CFC8;
  font-size: 26rpx; letter-spacing: 4rpx;
}

/* ===== list ===== */
.list {
  padding: 16rpx 32rpx 32rpx;
  display: flex; flex-direction: column; gap: 24rpx;
}
.item {
  display: flex; gap: 20rpx;
  padding: 24rpx;
  background: rgba(184, 207, 200, 0.06);
  border: 1rpx solid rgba(184, 207, 200, 0.12);
  border-radius: 16rpx;
}

.item-rank {
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
  flex: none;
}
.rank-num {
  width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center;
  border-radius: 50%;
  background: linear-gradient(160deg, #B8CFC8 0%, #8AAFA6 100%);
  color: #1F2828;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 26rpx; font-weight: 600;
}
.rank-tools { display: flex; flex-direction: column; gap: 8rpx; }
.rank-btn {
  width: 56rpx; height: 44rpx; line-height: 40rpx; text-align: center;
  border: 1rpx solid rgba(184, 207, 200, 0.3);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: rgba(236, 228, 212, 0.75);
}
.rank-btn.is-disabled {
  opacity: 0.3;
  pointer-events: none;
}

/* cover */
.item-cover {
  position: relative;
  width: 240rpx; height: 180rpx; /* 4:3 */
  flex: none;
  border-radius: 12rpx;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.3);
}
.cover { width: 100%; height: 100%; display: block; }
.cover-placeholder {
  width: 100%; height: 100%;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx;
  color: rgba(236, 228, 212, 0.5);
  border: 1rpx dashed rgba(184, 207, 200, 0.3);
  border-radius: 12rpx;
}
.ph-icon { font-size: 48rpx; color: rgba(184, 207, 200, 0.5); }
.ph-text { font-size: 22rpx; letter-spacing: 2rpx; }
.cover-mask {
  position: absolute; left: 0; right: 0; bottom: 0;
  padding: 8rpx;
  text-align: center;
  font-size: 22rpx; letter-spacing: 4rpx;
  color: #ECE4D4;
  background: linear-gradient(to top, rgba(0,0,0,0.65), rgba(0,0,0,0));
}
.cover-tag {
  position: absolute; top: 12rpx; left: 12rpx;
  padding: 4rpx 12rpx;
  font-size: 20rpx; letter-spacing: 2rpx;
  color: #ECE4D4;
  background: rgba(197, 106, 85, 0.85);
  border-radius: 4rpx;
}

/* meta */
.item-meta {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 8rpx;
}
.meta-title {
  font-family: "Songti SC", serif;
  font-size: 30rpx; color: #ECE4D4;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.meta-link {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; color: rgba(184, 207, 200, 0.7);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.meta-link--mute { color: rgba(236, 228, 212, 0.35); }

.meta-actions {
  margin-top: auto; padding-top: 8rpx;
  display: flex; gap: 12rpx; flex-wrap: wrap;
}
.act {
  padding: 10rpx 22rpx;
  border-radius: 6rpx;
  font-size: 22rpx; letter-spacing: 2rpx;
  border: 1rpx solid;
}
.act--edit {
  color: #B8CFC8;
  border-color: rgba(184, 207, 200, 0.4);
}
.act--off {
  color: rgba(236, 228, 212, 0.55);
  border-color: rgba(236, 228, 212, 0.25);
}
.act--on {
  color: #1F2828;
  background: #B8CFC8;
  border-color: #B8CFC8;
}
.act--del {
  color: #C56A55;
  border-color: rgba(197, 106, 85, 0.5);
}

.bottom-spacer { height: 240rpx; }

/* ===== footer ===== */
.footer {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(31,40,40,0.96) 60%, rgba(31,40,40,0));
}
.btn-save {
  height: 96rpx; line-height: 96rpx; text-align: center;
  background: linear-gradient(160deg, #B8CFC8 0%, #8AAFA6 100%);
  color: #1F2828;
  border-radius: 16rpx;
  font-family: "Songti SC", serif;
  font-size: 32rpx; letter-spacing: 8rpx;
}
.btn-save.is-busy { opacity: 0.6; }

/* ===== editor sheet ===== */
.editor-mask {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 50;
  display: flex; align-items: flex-end;
}
.editor-sheet {
  width: 100%;
  background: #232E2E;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 16rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  color: #ECE4D4;
  display: flex; flex-direction: column; gap: 24rpx;
}
.editor-handle {
  width: 80rpx; height: 6rpx;
  margin: 8rpx auto 16rpx;
  background: rgba(236, 228, 212, 0.2);
  border-radius: 3rpx;
}
.editor-title {
  font-family: "Songti SC", serif;
  font-size: 32rpx; letter-spacing: 6rpx;
  color: #ECE4D4;
}

.form-row {
  display: flex; flex-direction: column; gap: 12rpx;
}
.form-row--switch {
  flex-direction: row; align-items: center; justify-content: space-between;
}
.form-label {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; letter-spacing: 4rpx;
  color: rgba(184, 207, 200, 0.7);
}
.form-input {
  height: 76rpx;
  padding: 0 20rpx;
  background: rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(184, 207, 200, 0.18);
  border-radius: 10rpx;
  color: #ECE4D4;
  font-size: 26rpx;
}
.form-ph { color: rgba(236, 228, 212, 0.3); }

.editor-btns {
  display: flex; gap: 16rpx;
  padding-top: 8rpx;
}
.ed-btn {
  flex: 1;
  height: 88rpx; line-height: 88rpx; text-align: center;
  border-radius: 12rpx;
  font-family: "Songti SC", serif;
  font-size: 28rpx; letter-spacing: 6rpx;
}
.ed-btn--ghost {
  border: 1rpx solid rgba(184, 207, 200, 0.4);
  color: rgba(236, 228, 212, 0.75);
}
.ed-btn--solid {
  background: linear-gradient(160deg, #B8CFC8 0%, #8AAFA6 100%);
  color: #1F2828;
}
