.page { min-height: 100vh; background: #F6F1E6; color: #3A3A3A; }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 20;
  background: rgba(31, 40, 40, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.06);
}
.navbar-inner {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40rpx;
}
.nav-left { display: flex; align-items: center; gap: 16rpx; }
.brand {
  width: 44rpx; height: 44rpx; line-height: 44rpx; text-align: center;
  font-size: 28rpx; color: #5A8A80;
  border: 1rpx solid rgba(58, 58, 58, 0.25);
  border-radius: 4rpx;
}
.brand-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx; letter-spacing: 6rpx;
  color: #5A5A5A;
}
.nav-right {
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx; letter-spacing: 4rpx;
  color: #5A5A5A;
}

.hero {
  padding: 56rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.hero-greeting {
  font-size: 24rpx; letter-spacing: 8rpx;
  color: rgba(58, 58, 58, 0.5);
  font-family: "PingFang SC", sans-serif;
}
.hero-name {
  font-family: "Songti SC", "STSong", serif;
  font-size: 56rpx; letter-spacing: 4rpx;
  color: #3A3A3A;
}
.hero-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx; letter-spacing: 2rpx;
  color: rgba(90, 138, 128, 0.7);
}

.kpi-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 0;
}
.kpi-card {
  flex: 1.3;
  background: linear-gradient(160deg, #B8CFC8 0%, #5A8A80 100%);
  color: #F6F1E6;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-height: 220rpx;
  justify-content: space-between;
}
.kpi-label {
  font-size: 22rpx; letter-spacing: 6rpx;
  font-family: "PingFang SC", sans-serif;
  color: rgba(31, 40, 40, 0.65);
}
.kpi-value {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 88rpx;
  line-height: 1;
  color: #F6F1E6;
  font-weight: 500;
}
.kpi-action {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; letter-spacing: 4rpx;
  color: rgba(31, 40, 40, 0.7);
}

.kpi-col { flex: 1; display: flex; flex-direction: column; gap: 16rpx; }
.kpi-mini {
  flex: 1;
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 58, 58, 0.08);
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}
.kpi-mini-label {
  font-size: 22rpx; letter-spacing: 4rpx;
  color: rgba(58, 58, 58, 0.55);
  font-family: "PingFang SC", sans-serif;
}
.kpi-mini-value {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 44rpx; color: #3A3A3A;
}
.kpi-mini-value .unit { font-size: 22rpx; margin-right: 4rpx; color: #5A5A5A; }

.block { padding: 48rpx 32rpx 0; }
.block-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding: 0 8rpx 20rpx;
}
.head-cn {
  font-size: 28rpx; letter-spacing: 6rpx; color: #3A3A3A;
}
.head-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx; letter-spacing: 6rpx;
  color: rgba(58, 58, 58, 0.45);
}

.status-grid {
  display: flex;
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 58, 58, 0.08);
  border-radius: 16rpx;
  overflow: hidden;
}
.status-cell {
  flex: 1;
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border-right: 1rpx solid rgba(58, 58, 58, 0.06);
}
.status-cell:last-child { border-right: none; }
.status-num {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 44rpx;
  color: #5A8A80;
}
.status-label {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; letter-spacing: 2rpx;
  color: #5A5A5A;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.grid--2 { grid-template-columns: repeat(2, 1fr); }
.grid-item {
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 58, 58, 0.08);
  border-radius: 16rpx;
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.grid-item.warn { background: rgba(232, 156, 142, 0.08); border-color: rgba(232, 156, 142, 0.3); }
.grid-num {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 44rpx; color: #3A3A3A;
}
.grid-item.warn .grid-num { color: #E89C8E; }
.grid-label {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx; letter-spacing: 2rpx;
  color: #5A5A5A;
}

.actions {
  margin-top: 48rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.action {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(184, 207, 200, 0.1);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}
.action-glyph {
  width: 64rpx; height: 64rpx; line-height: 64rpx; text-align: center;
  background: rgba(58, 58, 58, 0.08);
  color: #5A8A80;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.action-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.action-cn { font-size: 28rpx; color: #3A3A3A; letter-spacing: 2rpx; }
.action-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx; letter-spacing: 6rpx;
  color: rgba(58, 58, 58, 0.5);
}
.action-arrow { color: rgba(58, 58, 58, 0.55); font-size: 36rpx; }
