<view class="page">
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <text class="back" bindtap="back">‹</text>
      <view class="page-title">
        <text class="t-cn">订单详情</text>
        <text class="t-en">ORDER DETAIL</text>
      </view>
      <view></view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view wx:if="{{loading}}" class="empty">载入中…</view>

    <block wx:elif="{{order}}">
      <view class="hero">
        <text class="hero-status status-{{order.statusKey}}">{{order.statusLabel}}</text>
        <text class="hero-note">{{order.statusNote}}</text>
        <view class="hero-meta" bindtap="copyOrderNo">
          <text class="hero-no">单号 {{order.orderNo}}</text>
          <text class="copy">复制</text>
        </view>
      </view>

      <view class="block">
        <view class="block-head">
          <text class="head-cn">收件信息</text>
          <text class="head-en">SHIPPING TO</text>
        </view>
        <view wx:if="{{order.address}}" class="info-card">
          <view class="info-row">
            <text class="info-name">{{order.address.receiver}}</text>
            <text class="info-phone">{{order.address.phone}}</text>
          </view>
          <text class="info-detail">{{order.address.full}}</text>
        </view>
        <view wx:else class="info-card empty-card">未填写收件地址</view>
        <view wx:if="{{order.remark}}" class="remark">买家留言：{{order.remark}}</view>
      </view>

      <view class="block">
        <view class="block-head">
          <text class="head-cn">商品</text>
          <text class="head-en">ITEMS · {{order.itemsCount}}</text>
        </view>
        <view class="items">
          <view wx:for="{{order.items}}" wx:key="id" class="item-row">
            <image class="item-img" src="{{item.image}}" mode="aspectFill"></image>
            <view class="item-meta">
              <text class="item-name">{{item.name}}</text>
              <text wx:if="{{item.spec}}" class="item-spec">{{item.spec}}</text>
              <view class="item-bottom">
                <text class="item-price"><text class="unit">¥</text>{{item.price}}</text>
                <text class="item-qty">× {{item.quantity}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="totals">
          <view class="totals-row"><text>商品小计</text><text><text class="unit">¥</text>{{order.subtotal}}</text></view>
          <view class="totals-row"><text>运费</text><text><text class="unit">¥</text>{{order.freight}}</text></view>
          <view wx:if="{{order.discount > 0}}" class="totals-row"><text>优惠</text><text>-<text class="unit">¥</text>{{order.discount}}</text></view>
          <view class="totals-row totals-row--accent">
            <text>实付</text>
            <text class="big"><text class="unit">¥</text>{{order.total}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{order.statusKey === 'pending_ship'}}" class="block">
        <view class="block-head">
          <text class="head-cn">填写运单</text>
          <text class="head-en">SHIPMENT</text>
        </view>
        <view class="form">
          <view class="form-field">
            <text class="form-label">快递公司</text>
            <input
              class="form-input"
              value="{{shipForm.company}}"
              placeholder="如：顺丰速运"
              placeholder-class="ph"
              bindinput="onCompanyInput"
              bindblur="hideHints"
            />
            <view wx:if="{{showHints}}" class="hints">
              <view
                wx:for="{{companyHints}}"
                wx:key="*this"
                data-value="{{item}}"
                catchtap="pickHint"
                class="hint"
              >
                {{item}}
              </view>
            </view>
          </view>
          <view class="form-field">
            <text class="form-label">运单号</text>
            <view class="form-row">
              <input
                class="form-input"
                value="{{shipForm.trackingNo}}"
                placeholder="可扫描运单条码"
                placeholder-class="ph"
                bindinput="onTrackingInput"
              />
              <view class="scan" bindtap="scanTracking">
                <text>扫</text>
              </view>
            </view>
          </view>
          <view class="form-field">
            <text class="form-label">备注（选填）</text>
            <input
              class="form-input"
              value="{{shipForm.remark}}"
              placeholder="例如：圆通已上门取件"
              placeholder-class="ph"
              bindinput="onRemarkInput"
            />
          </view>
          <view class="submit {{submitting ? 'submit--loading' : ''}}" bindtap="doShip">
            <text>{{submitting ? '提交中…' : '确认发货'}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{logistics && (logistics.company || logistics.trackingNo || logistics.no)}}" class="block">
        <view class="block-head">
          <text class="head-cn">物流</text>
          <text class="head-en">LOGISTICS</text>
        </view>
        <view class="info-card">
          <view class="info-row">
            <text class="info-name">{{logistics.company || logistics.companyName}}</text>
            <text class="copy" data-value="{{logistics.trackingNo || logistics.no}}" catchtap="copyTrackingNo">复制单号</text>
          </view>
          <text class="info-detail">{{logistics.trackingNo || logistics.no}}</text>
        </view>
      </view>

      <view class="block">
        <view class="block-head">
          <text class="head-cn">操作</text>
          <text class="head-en">ACTIONS</text>
        </view>
        <view class="actions">
          <view wx:if="{{order.statusKey === 'pending_pay'}}" class="op" bindtap="markPaid">
            <text>标记已付款</text>
          </view>
          <view wx:if="{{order.statusKey === 'shipped'}}" class="op" bindtap="markComplete">
            <text>标记已完成</text>
          </view>
          <view wx:if="{{order.statusKey === 'pending_pay' || order.statusKey === 'pending_ship'}}" class="op danger" bindtap="closeOrder">
            <text>关闭订单</text>
          </view>
        </view>
      </view>
    </block>

    <view style="height: 200rpx;"></view>
  </scroll-view>
</view>
