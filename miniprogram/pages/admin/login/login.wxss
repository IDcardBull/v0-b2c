.page {
  min-height: 100vh;
  background: #F6F1E6;
  color: #3A3A3A;
  font-family: "Songti SC", "STSong", serif;
}
.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 20; }
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.back {
  width: 64rpx; line-height: 1; font-size: 56rpx; color: #3A3A3A;
}
.page-title { text-align: center; flex: 1; }
.t-cn { font-size: 30rpx; letter-spacing: 8rpx; color: #3A3A3A; }
.t-en {
  display: block;
  margin-top: 4rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 6rpx;
  color: rgba(58, 58, 58, 0.55);
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx 60rpx;
}
.hero-seal {
  width: 120rpx; height: 120rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.25);
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; color: #5A8A80;
  background: rgba(58, 58, 58, 0.06);
}
.hero-title {
  margin-top: 36rpx;
  font-size: 44rpx;
  letter-spacing: 6rpx;
  color: #3A3A3A;
}
.hero-sub {
  margin-top: 12rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: #5A5A5A;
}

.card {
  margin: 0 60rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 58, 58, 0.1);
  border-radius: 16rpx;
  padding: 48rpx 40rpx 40rpx;
}
.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.08);
}
.field:last-of-type { border-bottom: none; }
.label {
  font-size: 20rpx; letter-spacing: 6rpx;
  color: #5A8A80;
  font-family: "PingFang SC", sans-serif;
}
.input {
  font-family: "PingFang SC", sans-serif;
  font-size: 28rpx;
  color: #3A3A3A;
  letter-spacing: 2rpx;
}
.ph { color: rgba(58, 58, 58, 0.35); }

.error {
  margin-top: 16rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx;
  color: #E89C8E;
  letter-spacing: 2rpx;
}

.submit {
  margin-top: 48rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #5A8A80;
  color: #F6F1E6;
  border-radius: 8rpx;
  font-size: 30rpx;
  letter-spacing: 8rpx;
  transition: opacity 0.2s ease;
}
.submit--loading { opacity: 0.6; }

.tip {
  display: block;
  margin-top: 32rpx;
  text-align: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: rgba(58, 58, 58, 0.45);
  letter-spacing: 1rpx;
}
