<view class="page">
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <view class="back" bindtap="back"><text>‹</text></view>
      <view class="page-title">
        <text class="t-cn">工作台</text>
        <text class="t-en">ADMIN ACCESS</text>
      </view>
      <view></view>
    </view>
  </view>

  <view class="hero" style="padding-top: {{statusBarHeight + navBarHeight + 80}}rpx;">
    <text class="hero-seal">釉</text>
    <text class="hero-title">主理人入席</text>
    <text class="hero-sub">凭账号密码进入移动工作台</text>
  </view>

  <view class="card">
    <view class="field">
      <text class="label">账号</text>
      <input
        class="input"
        value="{{username}}"
        bindinput="onUsername"
        placeholder="后台账号"
        placeholder-class="ph"
        confirm-type="next"
        adjust-position
      />
    </view>
    <view class="field">
      <text class="label">密码</text>
      <input
        class="input"
        value="{{password}}"
        bindinput="onPassword"
        password
        placeholder="6 位以上"
        placeholder-class="ph"
        confirm-type="done"
        bindconfirm="submit"
        adjust-position
      />
    </view>

    <view wx:if="{{error}}" class="error">{{error}}</view>

    <view class="submit {{loading ? 'submit--loading' : ''}}" bindtap="submit">
      <text>{{loading ? '验证中…' : '进入工作台'}}</text>
    </view>

    <text class="tip">仅限授权员工使用，登录信息不会向客户公开</text>
  </view>
</view>
