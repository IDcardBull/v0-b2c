.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: transparent;
  transition: background 0.35s ease, border-color 0.35s ease;
}
.navbar--solid {
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.05);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
}
.back, .share {
  width: 68rpx; height: 68rpx;
  background: rgba(239, 232, 220, 0.88);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(58, 58, 58, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  border: 1rpx solid rgba(58, 58, 58, 0.06);
}
.back:active, .share:active {
  transform: scale(0.9);
  box-shadow: 0 1rpx 4rpx rgba(58, 58, 58, 0.1);
}
.back-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 40rpx;
  color: var(--color-ink);
  line-height: 1;
  padding-bottom: 4rpx;
}
.share {
  flex-direction: row;
  gap: 6rpx;
}
.share-dot {
  width: 6rpx; height: 6rpx;
  border-radius: 50%;
  background: var(--color-ink);
}
.nav-title {
  opacity: 0;
  transition: opacity 0.35s ease;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
}
.nav-title--show { opacity: 1; }

/* 图册 —— 增加视觉冲击 */
.gallery {
  position: relative;
  margin-top: -88rpx;
  padding: 0;
  background: var(--color-paper);
}
.swiper {
  width: 100%;
  height: 920rpx;
}
.gallery-img {
  width: 100%;
  height: 100%;
  background: var(--color-paper);
}
.gallery-dots {
  position: absolute;
  right: 40rpx;
  bottom: 40rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 12rpx 22rpx;
  background: rgba(239, 232, 220, 0.85);
  backdrop-filter: blur(12rpx);
  font-family: "PingFang SC", sans-serif;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
}
.dot-num { font-size: 24rpx; color: var(--color-ink); font-weight: 500; }
.dot-sep { font-size: 20rpx; color: var(--color-ink-faint); margin: 0 2rpx; }
.dot-total { font-size: 20rpx; color: var(--color-ink-soft); }

.tag-badge {
  position: absolute;
  top: 140rpx;
  left: 40rpx;
  padding: 8rpx 20rpx;
  background: rgba(239, 232, 220, 0.88);
  backdrop-filter: blur(12rpx);
  border: 1rpx solid rgba(58, 58, 58, 0.15);
  border-radius: var(--radius-xs);
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
  box-shadow: var(--shadow-sm);
}

/* 标题区 —— 增加层次 */
.head {
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.head-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}
.name {
  flex: 1;
  font-family: "Songti SC", serif;
  font-size: 48rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  line-height: 1.35;
  font-weight: 600;
}
.collect {
  width: 76rpx; height: 76rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: var(--shadow-sm);
}
.collect:active {
  transform: scale(0.88);
}
.collect--on {
  border-color: var(--color-celadon-deep);
  background: var(--color-celadon-deep);
  box-shadow: 0 4rpx 16rpx rgba(138, 175, 166, 0.3);
}
.collect-char {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  transition: color 0.2s ease;
}
.collect--on .collect-char {
  color: #fff;
}
.sub {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.price-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  padding-top: 14rpx;
}
.price {
  font-size: 46rpx;
  font-weight: 600;
}
.price-note {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.price .dash {
  font-family: "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: var(--color-ink-soft);
  margin: 0 6rpx;
}
.meta-row {
  display: flex;
  gap: 14rpx;
  padding-top: 12rpx;
  flex-wrap: wrap;
}
.meta-text {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.1);
  border-radius: var(--radius-full);
  background: rgba(246, 241, 230, 0.6);
}

/* 规格入口 —— 卡片化 */
.spec-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  background: var(--color-paper);
  margin: 16rpx 40rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.05);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}
.spec-entry:active {
  transform: scale(0.98);
}
.spec-entry-left {
  display: flex;
  align-items: baseline;
  gap: 28rpx;
  flex: 1;
  min-width: 0;
}
.se-label {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
}
.se-value {
  flex: 1;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.se-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 36rpx;
  color: var(--color-ink-faint);
}

.hairline.m-x {
  margin: 0 40rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.08), transparent);
}

/* Section 标题 */
.section {
  padding: 48rpx 40rpx 16rpx;
}
.section-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.s-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 10rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.s-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

/* 介绍 */
.intro {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}
.intro-text {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  line-height: 1.9;
  letter-spacing: 2rpx;
  color: var(--color-ink);
}
.quote {
  align-self: flex-end;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  padding: 24rpx 0 0;
  color: var(--color-ink-soft);
}
.quote text:first-child {
  font-family: "Songti SC", serif;
  font-size: 32rpx;
  letter-spacing: 8rpx;
  color: var(--color-celadon-deep);
}
.quote-by {
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}

/* 工艺规格 —— 卡片化 */
.specs {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: var(--color-paper);
  padding: 32rpx 28rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.05);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.spec-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}
.spec-dot {
  width: 8rpx; height: 8rpx;
  background: var(--color-celadon-deep);
  border-radius: 50%;
}
.spec-text {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink);
}

/* 作坊 —— 卡片化 */
.maker {
  display: flex;
  gap: 24rpx;
  padding: 28rpx;
  background: var(--color-paper);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
}
.maker-avatar {
  width: 96rpx; height: 96rpx;
  background: linear-gradient(135deg, var(--color-celadon-light), var(--color-celadon));
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 34rpx;
  color: var(--color-ink);
  box-shadow: 0 2rpx 8rpx rgba(138, 175, 166, 0.2);
}
.maker-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.maker-name {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.maker-desc {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  line-height: 1.7;
}
.maker-link {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  color: var(--color-celadon-deep);
  letter-spacing: 4rpx;
  padding: 6rpx 0;
}
.maker-link .arrow {
  font-family: "PingFang SC", sans-serif;
  transition: transform 0.2s ease;
}
.maker-link:active .arrow {
  transform: translateX(6rpx);
}

/* 相似推荐 */
.related { white-space: nowrap; margin: 0 -40rpx; padding: 0 40rpx; }
.related-item {
  display: inline-flex;
  flex-direction: column;
  gap: 12rpx;
  width: 260rpx;
  margin-right: 20rpx;
  vertical-align: top;
  transition: transform 0.2s ease;
}
.related-item:active {
  transform: scale(0.96);
}
.related-img {
  width: 260rpx;
  height: 320rpx;
  background: var(--color-paper);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-sm);
}
.related-title {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.related-price { font-size: 24rpx; font-weight: 500; }

/* 结尾 */
.end-mark {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0 40rpx;
}
.end-seal {
  width: 68rpx;
  height: 68rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.3);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  color: var(--color-ink);
  transform: rotate(-3deg);
  box-shadow: var(--shadow-sm);
  background: rgba(246, 241, 230, 0.6);
}
.end-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

/* 底部行动栏 —— 增强质感 */
.action {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: rgba(239, 232, 220, 0.95);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  z-index: 30;
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.06);
}
.action-line {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.08), transparent);
  margin: 0 32rpx;
}
.action-inner {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}
.action-icon {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  transition: transform 0.2s ease;
}
.action-icon:active {
  transform: scale(0.88);
}
.ai-char {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  color: var(--color-ink);
}
.ai-label {
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
}
.ai-badge {
  position: absolute;
  top: 2rpx;
  right: 4rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: var(--color-celadon-deep);
  color: #fff;
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(138, 175, 166, 0.3);
}
.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  padding: 24rpx 0;
  border-radius: var(--radius-sm);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.action-btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}
.action-btn.secondary {
  background: transparent;
  color: var(--color-ink);
  border: 1.5rpx solid var(--color-ink);
}
.action-btn.primary {
  background: var(--color-ink);
  color: var(--color-bg);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}

/* 规格浮层 —— 增加动效和圆角 */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(30, 28, 24, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.25s ease;
}
.sheet {
  width: 100%;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  max-height: 80vh;
  border-top-left-radius: var(--radius-xl);
  border-top-right-radius: var(--radius-xl);
  overflow: visible;
  animation: slideUp 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  box-shadow: 0 -8rpx 40rpx rgba(58, 58, 58, 0.1);
}
.sheet-head {
  position: relative;
  display: flex;
  gap: 28rpx;
  padding: 32rpx 36rpx 24rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.06);
}
.sheet-img {
  width: 176rpx;
  height: 176rpx;
  margin-top: 0;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.06);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  object-fit: contain;
  box-shadow: var(--shadow-sm);
}
.sheet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 6rpx;
  min-width: 0;
}
.sheet-price {
  font-family: "PingFang SC", sans-serif;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-ink);
}
.sheet-price .unit {
  font-size: 24rpx;
  color: var(--color-ink-soft);
  margin-right: 4rpx;
  font-weight: 400;
}
.sheet-stock {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.sheet-pick {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-soft);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.sheet-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(58, 58, 58, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 36rpx;
  color: var(--color-ink-soft);
  transition: background 0.2s ease;
}
.sheet-close:active {
  background: rgba(58, 58, 58, 0.12);
}

.sheet-body {
  flex: 1;
  padding: 16rpx 36rpx 8rpx;
  max-height: 56vh;
}
.spec-group {
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.05);
}
.spec-group:last-child {
  border-bottom: none;
}
.spec-name {
  display: block;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
  margin-bottom: 20rpx;
}
.spec-values {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.spec-chip {
  padding: 16rpx 28rpx;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.12);
  border-radius: var(--radius-sm);
  transition: all 0.25s ease;
}
.spec-chip:active {
  transform: scale(0.95);
}
.spec-chip--on {
  color: #fff;
  background: var(--color-ink);
  border-color: var(--color-ink);
  box-shadow: 0 2rpx 12rpx rgba(58, 58, 58, 0.15);
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0 8rpx;
  border-top: 1rpx solid rgba(58, 58, 58, 0.05);
}
.qty-label {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
}
.stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.step {
  width: 60rpx;
  height: 60rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 32rpx;
  color: var(--color-ink);
  transition: all 0.2s ease;
}
.step:active {
  background: var(--color-ink);
  color: var(--color-bg);
  border-color: var(--color-ink);
  transform: scale(0.9);
}
.qty-num {
  font-family: "PingFang SC", sans-serif;
  font-size: 32rpx;
  min-width: 60rpx;
  text-align: center;
  color: var(--color-ink);
  font-weight: 500;
}

.sheet-bottom {
  padding: 20rpx 36rpx 28rpx;
  background: var(--color-bg);
  border-top: 1rpx solid rgba(58, 58, 58, 0.05);
}
.sheet-btn {
  width: 100%;
  height: 96rpx;
  background: var(--color-ink);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 8rpx;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 20rpx rgba(58, 58, 58, 0.15);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.sheet-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
