.page {
  min-height: 100vh;
  background: var(--color-bg);
  position: relative;
}

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 10;
  background: var(--color-bg);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}
.page-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 14rpx;
  color: var(--color-ink);
  padding-left: 14rpx;
  font-weight: 600;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

.wrap {
  min-height: 100vh;
  padding: 0 56rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  animation: fadeInUp 0.5s ease;
}

/* 状态印 */
.seal {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 38rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  background: var(--color-paper);
  box-shadow: var(--shadow-md);
}
.seal.ok {
  border-color: var(--color-celadon);
  color: var(--color-celadon-deep);
  background: linear-gradient(135deg, rgba(212, 229, 224, 0.3), rgba(184, 207, 200, 0.15));
  box-shadow: 0 4rpx 20rpx rgba(138, 175, 166, 0.2);
}
.seal.warn {
  border-color: rgba(170, 80, 60, 0.3);
  color: #aa503c;
  background: rgba(170, 80, 60, 0.06);
}
.seal.pending {
  border-color: rgba(58, 58, 58, 0.15);
  color: var(--color-ink-soft);
}

.title {
  font-family: "Songti SC", serif;
  font-size: 40rpx;
  letter-spacing: 14rpx;
  color: var(--color-ink);
  padding-left: 14rpx;
  margin-top: 4rpx;
  font-weight: 600;
}
.sub {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
  text-align: center;
  max-width: 520rpx;
}

/* 回执卡 */
.receipt {
  width: 100%;
  margin-top: 24rpx;
  padding: 32rpx 32rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.receipt-row {
  display: flex;
  align-items: baseline;
  gap: 24rpx;
}
.r-key {
  width: 90rpx;
  flex-shrink: 0;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-faint);
}
.r-val {
  flex: 1;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  word-break: break-all;
}
.r-val.price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 34rpx;
  font-weight: 600;
}
.r-val.price .unit {
  font-size: 22rpx;
  color: var(--color-ink-soft);
  margin-right: 4rpx;
  font-weight: 400;
}

/* 操作按钮 */
.actions {
  width: 100%;
  margin-top: 28rpx;
  display: flex;
  gap: 18rpx;
}
.btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 10rpx;
  border-radius: var(--radius-sm);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}
.btn.solid {
  background: var(--color-ink);
  color: var(--color-bg);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}
.btn.ghost {
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  color: var(--color-ink);
  background: transparent;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
