<view class="page">
  <!-- 顶部：状态栏占位 + 搜索栏 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <view class="page-title">
        <text class="t-cn">品类</text>
        <text class="t-en">CATEGORY</text>
      </view>
      <view class="search" bindtap="onSearch">
        <view class="search-icon">
          <view class="circle"></view>
          <view class="stick"></view>
        </view>
        <text class="search-ph">查找器物</text>
      </view>
    </view>
  </view>

  <view class="body" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <!-- 左侧分类 -->
    <scroll-view scroll-y class="rail">
      <block wx:for="{{categories}}" wx:key="id">
        <view
          class="rail-item rail-item--parent {{current === item.id ? 'rail-item--on' : ''}}"
          data-id="{{item.id}}"
          bindtap="onTapCat"
        >
          <view class="rail-bar"></view>
          <view class="rail-text">
            <text class="rail-cn">{{item.name}}</text>
            <text class="rail-en">{{item.sub}}</text>
          </view>
        </view>
        <view
          wx:for="{{item.children}}"
          wx:for-item="child"
          wx:key="id"
          class="rail-item rail-item--child {{current === child.id ? 'rail-item--on' : ''}}"
          data-id="{{child.id}}"
          bindtap="onTapCat"
        >
          <view class="rail-bar"></view>
          <view class="rail-text">
            <text class="rail-cn">{{child.name}}</text>
            <text class="rail-en">{{child.sub}}</text>
          </view>
        </view>
      </block>
    </scroll-view>

    <!-- 右侧商品 -->
    <scroll-view scroll-y class="content">
      <view class="head">
        <text class="head-cn">{{currentMeta.name}}</text>
        <text class="head-desc">{{currentMeta.desc}}</text>
      </view>

      <view class="list">
        <view
          wx:for="{{list}}"
          wx:key="id"
          class="item"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >
          <image class="item-img" src="{{item.mainImage}}" mode="aspectFill"></image>
          <view class="item-meta">
            <view class="item-title-row">
              <text class="item-title">{{item.name}}</text>
              <text wx:if="{{item.tag}}" class="seal">{{item.tag}}</text>
            </view>
            <text class="item-sub">{{item.sub}}</text>
            <view class="item-price price">
              <text class="unit">¥</text>{{item.price}}
            </view>
          </view>
        </view>

        <view wx:if="{{list.length === 0}}" class="empty">
          <text>暂无器物</text>
        </view>

        <view class="end-text">— 止 —</view>
      </view>
      <view style="height: 200rpx;"></view>
    </scroll-view>
  </view>
</view>
