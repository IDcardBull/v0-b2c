.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.9);
  backdrop-filter: blur(20rpx);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  gap: 24rpx;
}
.page-title {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.t-cn {
  font-family: "Songti SC", serif;
  font-size: 32rpx;
  letter-spacing: 10rpx;
  color: var(--color-ink);
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
}

/* 搜索栏：透明 */
.search {
  flex: 1;
  max-width: 360rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.18);
  border-radius: 28rpx;
  background: transparent;
}
.search-icon {
  position: relative;
  width: 22rpx;
  height: 22rpx;
}
.search-icon .circle {
  width: 16rpx;
  height: 16rpx;
  border: 1rpx solid var(--color-ink-soft);
  border-radius: 50%;
}
.search-icon .stick {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 10rpx;
  height: 1rpx;
  background: var(--color-ink-soft);
  transform: rotate(45deg);
  transform-origin: left center;
}
.search-ph {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  color: var(--color-ink-faint);
  letter-spacing: 4rpx;
}

/* 主体：左右栏 */
.body {
  display: flex;
  height: 100vh;
  box-sizing: border-box;
}
.rail {
  width: 200rpx;
  background: transparent;
  box-sizing: border-box;
  padding-top: 24rpx;
  border-right: 1rpx solid rgba(58, 58, 58, 0.08);
}
.rail-item {
  display: flex;
  align-items: stretch;
  padding: 28rpx 0 28rpx 30rpx;
  gap: 16rpx;
}
.rail-bar {
  width: 2rpx;
  background: transparent;
}
.rail-item--on .rail-bar {
  background: var(--color-ink);
}
.rail-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.rail-cn {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
}
.rail-item--on .rail-cn {
  color: var(--color-ink);
  font-weight: 500;
}
.rail-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}

.content {
  flex: 1;
  padding: 24rpx 32rpx 0 32rpx;
}
.head {
  padding: 12rpx 8rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.08);
  margin-bottom: 28rpx;
}
.head-cn {
  font-family: "Songti SC", serif;
  font-size: 38rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
}
.head-desc {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  padding-bottom: 40rpx;
}
.item {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.item-img {
  width: 100%;
  height: 560rpx;
  background: var(--color-paper);
  border-radius: 4rpx;
}
.item-meta {
  padding: 0 6rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.item-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}
.item-title {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
}
.seal {
  flex-shrink: 0;
  font-family: "Songti SC", serif;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  padding: 2rpx 10rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.18);
}
.item-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}
.item-price {
  font-size: 28rpx;
  padding-top: 4rpx;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: var(--color-ink-faint);
  font-size: 24rpx;
  letter-spacing: 4rpx;
}
.end-text {
  text-align: center;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  letter-spacing: 8rpx;
  padding: 40rpx 0;
}
