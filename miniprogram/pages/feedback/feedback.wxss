.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
}
.back {
  width: 68rpx; height: 68rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  transition: transform 0.2s ease;
}
.back:active { transform: scale(0.85); }
.back-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 40rpx;
  color: var(--color-ink);
  line-height: 1;
}
.page-title { display: flex; align-items: baseline; gap: 12rpx; }
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

.hero {
  margin: 24rpx 32rpx 0;
  padding: 36rpx 32rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
}
.hero-quote {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  line-height: 1.7;
  color: var(--color-ink);
}
.hero-by {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}

/* 区块 */
.section {
  padding: 36rpx 40rpx 0;
}
.section-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.s-cn {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.s-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}
.counter {
  margin-left: auto;
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  color: var(--color-ink-faint);
}

/* 类型 */
.types {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.type {
  flex: 1;
  min-width: 200rpx;
  padding: 24rpx 20rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.08);
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.25s ease;
}
.type:active {
  transform: scale(0.96);
}
.type--on {
  border-color: var(--color-ink);
  background: var(--color-ink);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}
.type-cn {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
}
.type-sub {
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}
.type--on .type-cn,
.type--on .type-sub {
  color: var(--color-bg);
}

/* 输入 */
.input {
  width: 100%;
  padding: 24rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.05);
  border-radius: var(--radius-sm);
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}
.textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.05);
  border-radius: var(--radius-sm);
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  box-sizing: border-box;
}
.ph {
  color: var(--color-ink-faint);
  font-family: "Songti SC", serif;
  letter-spacing: 2rpx;
}

/* 凭证图 */
.images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.img-cell {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.05);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.img {
  width: 100%;
  height: 100%;
}
.img-del {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 38rpx; height: 38rpx;
  border-radius: 50%;
  background: var(--color-ink);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 26rpx;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(58, 58, 58, 0.2);
}
.img-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 1.5rpx dashed rgba(58, 58, 58, 0.2);
  border-radius: var(--radius-sm);
  transition: background 0.2s ease;
}
.img-add:active {
  background: rgba(184, 207, 200, 0.15);
}
.img-add--loading {
  background: rgba(184, 207, 200, 0.2);
}
.add-cross {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  display: flex; align-items: center; justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: var(--color-ink-soft);
}
.add-text {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.hint-line {
  margin-top: 18rpx;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  line-height: 1.7;
}

/* 底栏 */
.action {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: rgba(239, 232, 220, 0.95);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  z-index: 30;
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.05);
}
.action-line {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.08), transparent);
  margin: 0 32rpx;
}
.action-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}
.hint {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink-faint);
}
.submit {
  flex: 1;
  max-width: 360rpx;
  padding: 24rpx 0;
  text-align: center;
  background: rgba(58, 58, 58, 0.35);
  color: var(--color-bg);
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 10rpx;
  border-radius: var(--radius-sm);
  transition: all 0.25s ease;
}
.submit--on {
  background: var(--color-ink);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}
.submit--on:active {
  transform: scale(0.96);
  opacity: 0.9;
}
