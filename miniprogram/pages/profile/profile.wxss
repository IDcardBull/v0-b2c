.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.scroll { height: 100vh; box-sizing: border-box; }

/* 导航 */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.page-title {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}
.setting {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 20rpx;
  transition: transform 0.2s ease;
}
.setting:active {
  transform: scale(0.85);
}
.setting-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: var(--color-ink-soft);
}

/* 个人信息卡 —— 增加层次感 */
.hero-card {
  margin: 24rpx 32rpx 0;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}
.hero-card::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-celadon-light), transparent);
  opacity: 0.4;
  pointer-events: none;
}

/* 头像 */
.avatar {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-celadon-light), var(--color-celadon));
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(138, 175, 166, 0.25);
}
.avatar-char {
  font-family: "Songti SC", serif;
  font-size: 46rpx;
  color: var(--color-ink);
  letter-spacing: 0;
}
.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}
.avatar-edit {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: var(--color-ink);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  border: 3rpx solid var(--color-paper);
  box-shadow: 0 2rpx 8rpx rgba(58, 58, 58, 0.2);
}

/* 用户信息 */
.user {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}
.user-name-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.user-name {
  font-family: "Songti SC", serif;
  font-size: 38rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 600;
}
.vip {
  font-family: "Songti SC", serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--color-ink), #555);
  padding: 4rpx 14rpx;
  flex-shrink: 0;
  border-radius: var(--radius-xs);
}
.user-motto {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-soft);
}
.profile-edit-btn {
  align-self: flex-start;
  margin-top: 4rpx;
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.15);
  border-radius: var(--radius-full);
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 5rpx;
  color: var(--color-ink-soft);
  transition: all 0.2s ease;
}
.profile-edit-btn:active {
  background: rgba(58, 58, 58, 0.06);
  transform: scale(0.95);
}

/* 统计 */
.stats {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.stat {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.stat-num {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 32rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.stat-label {
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  color: var(--color-ink-faint);
  letter-spacing: 4rpx;
}
.vbar {
  width: 1rpx;
  height: 36rpx;
  background: linear-gradient(180deg, transparent, rgba(58, 58, 58, 0.15), transparent);
}

/* 订单区块 */
.block {
  margin: 40rpx 32rpx 0;
  padding: 32rpx 0 0;
}
.block-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 8rpx 28rpx;
}
.head-left {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.h-cn {
  font-family: "Songti SC", serif;
  font-size: 32rpx;
  letter-spacing: 10rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.h-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}
.all-orders {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  color: var(--color-celadon-deep);
  letter-spacing: 4rpx;
  padding: 8rpx 0;
}
.all-orders .arrow {
  font-family: "PingFang SC", sans-serif;
  color: var(--color-celadon-deep);
  font-size: 22rpx;
  transition: transform 0.2s ease;
}
.all-orders:active .arrow {
  transform: translateX(6rpx);
}

/* 订单状态图标 */
.orders {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 8rpx 0;
}
.order {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: transform 0.2s ease;
}
.order:active {
  transform: scale(0.9);
}
.order-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(58, 58, 58, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  color: var(--color-ink);
  background: var(--color-paper);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}
.order:active .order-icon {
  background: var(--color-celadon-light);
  border-color: var(--color-celadon);
}
.order-label {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.dot-badge {
  position: absolute;
  top: -4rpx;
  right: 40rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: var(--color-celadon-deep);
  color: #fff;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  font-family: "PingFang SC", sans-serif;
  box-shadow: 0 2rpx 8rpx rgba(138, 175, 166, 0.3);
}

/* 菜单列表 */
.menu {
  margin: 40rpx 32rpx 0;
  border-top: 1rpx solid rgba(58, 58, 58, 0.06);
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 8rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.05);
  transition: background 0.2s ease;
}
.menu-item:active {
  background: rgba(184, 207, 200, 0.08);
}
.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.menu-char {
  width: 56rpx;
  height: 56rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  color: var(--color-ink);
  background: var(--color-paper);
  box-shadow: var(--shadow-sm);
}
.menu-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.menu-label {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
}
.menu-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}
.menu-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 32rpx;
  color: var(--color-ink-faint);
}

/* 底部品牌 */
.footer {
  padding: 80rpx 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.footer-seal {
  width: 100rpx;
  height: 100rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.25);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  writing-mode: vertical-rl;
  transform: rotate(-2deg);
  box-shadow: var(--shadow-sm);
  background: rgba(246, 241, 230, 0.5);
}
.footer-line {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 10rpx;
  color: var(--color-ink-soft);
  margin-top: 12rpx;
}
.footer-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

/* 编辑资料弹层 —— 增加动效 */
.edit-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(20, 18, 14, 0.4);
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.25s ease;
}
.edit-panel {
  width: 100%;
  padding: 40rpx 40rpx calc(env(safe-area-inset-bottom) + 44rpx);
  background: var(--color-bg);
  border-top-left-radius: var(--radius-xl);
  border-top-right-radius: var(--radius-xl);
  box-shadow: 0 -12rpx 48rpx rgba(58, 58, 58, 0.12);
  animation: slideUp 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.edit-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 36rpx;
}
.edit-title {
  display: block;
  font-family: "Songti SC", serif;
  font-size: 36rpx;
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.edit-sub {
  display: block;
  margin-top: 8rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}
.edit-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(58, 58, 58, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 42rpx;
  color: var(--color-ink-soft);
  transition: background 0.2s ease;
}
.edit-close:active {
  background: rgba(58, 58, 58, 0.12);
}
.edit-field {
  margin-bottom: 28rpx;
}
.edit-label {
  display: block;
  margin-bottom: 14rpx;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink-soft);
}
.edit-input, .edit-textarea {
  width: 100%;
  box-sizing: border-box;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.06);
  border-radius: var(--radius-sm);
  color: var(--color-ink);
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 2rpx;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.edit-input {
  height: 92rpx;
  padding: 0 24rpx;
}
.edit-textarea {
  height: 180rpx;
  padding: 22rpx 24rpx;
  line-height: 1.7;
}
.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}
.edit-cancel, .edit-save {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 10rpx;
  border-radius: var(--radius-sm);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.edit-cancel:active, .edit-save:active {
  transform: scale(0.96);
  opacity: 0.85;
}
.edit-cancel {
  border: 1.5rpx solid rgba(58, 58, 58, 0.18);
  color: var(--color-ink-soft);
}
.edit-save {
  background: var(--color-ink);
  color: var(--color-bg);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}
.ph { color: var(--color-ink-faint); }

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 紧凑底部 — 给 tabbar 留出空间 */
.footer-mini {
  display: flex;
  justify-content: center;
  padding: 48rpx 0 calc(env(safe-area-inset-bottom) + 200rpx);
}
.footer-mini-seal {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink-faint);
  padding: 12rpx 24rpx;
  opacity: 0.5;
}
