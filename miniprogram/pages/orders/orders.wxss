.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.back {
  font-family: "PingFang SC", sans-serif;
  font-size: 56rpx;
  width: 64rpx;
  text-align: left;
  color: var(--color-ink);
  line-height: 1;
  transition: transform 0.2s ease;
}
.back:active {
  transform: scale(0.85);
}
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-family: "Songti SC", serif; font-size: var(--fs-h2); letter-spacing: 12rpx; color: var(--color-ink); font-weight: 600; }
.t-en { font-family: "PingFang SC", sans-serif; font-size: 20rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); opacity: 0.7; }

/* Tabs —— 增加精致感 */
.tabs {
  position: fixed;
  left: 0; right: 0;
  z-index: 19;
  height: 88rpx;
  background: rgba(239, 232, 220, 0.96);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  display: flex;
  padding: 0 24rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.05);
}
.tab {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 5rpx;
  color: var(--color-ink-faint);
  transition: color 0.25s ease;
}
.tab:active {
  opacity: 0.7;
}
.tab--on { color: var(--color-ink); font-weight: 500; }
.tab-line {
  position: absolute;
  bottom: 16rpx;
  width: 36rpx;
  height: 3rpx;
  background: var(--color-celadon-deep);
  border-radius: 2rpx;
  transition: width 0.3s ease;
}

/* Empty */
.empty {
  padding: 200rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  animation: fadeInUp 0.5s ease;
}
.empty-seal {
  width: 116rpx;
  height: 116rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 38rpx;
  color: var(--color-ink);
  background: rgba(246, 241, 230, 0.6);
  box-shadow: var(--shadow-md);
}
.empty-cn {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
}
.empty-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}

/* Cards —— 卡片化 */
.card {
  margin: 20rpx 32rpx 0;
  padding: 0;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: transform 0.2s ease;
}
.card:active {
  transform: scale(0.98);
}
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.order-no {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  letter-spacing: 1rpx;
}
.status {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: var(--color-celadon-deep);
  font-weight: 500;
}

.goods-list {
  padding: 8rpx 28rpx;
}
.goods-row {
  display: flex;
  gap: 22rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.03);
}
.goods-row:last-child { border-bottom: none; }
.goods-img {
  width: 150rpx;
  height: 170rpx;
  background: var(--color-card);
  flex-shrink: 0;
  border-radius: var(--radius-sm);
}
.goods-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.goods-name {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 500;
}
.goods-spec {
  align-self: flex-start;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-soft);
  background: rgba(184, 207, 200, 0.12);
  padding: 6rpx 14rpx;
  border-radius: var(--radius-xs);
}
.goods-bottom {
  margin-top: auto;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.goods-price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 26rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.goods-price .unit { font-size: 20rpx; color: var(--color-ink-soft); margin-right: 2rpx; font-weight: 400; }
.goods-qty {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-soft);
}

.card-foot {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 22rpx 28rpx;
  border-top: 1rpx solid rgba(58, 58, 58, 0.04);
}
.card-time,
.card-qty {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
}
.amount {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.amount .price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: var(--color-ink);
  font-weight: 600;
  letter-spacing: 0;
}
.amount .unit {
  font-size: 20rpx;
  color: var(--color-ink-soft);
  margin-right: 2rpx;
  font-weight: 400;
}

.end-text {
  text-align: center;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  letter-spacing: 8rpx;
  padding: 40rpx 0;
  opacity: 0.7;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 28rpx 24rpx;
}
.action {
  height: 64rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  border-radius: var(--radius-full);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.action:active {
  transform: scale(0.92);
  opacity: 0.8;
}
.action.ghost {
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  color: var(--color-ink);
  background: transparent;
}
.action.solid {
  background: var(--color-ink);
  color: var(--color-bg);
  box-shadow: 0 2rpx 12rpx rgba(58, 58, 58, 0.12);
}

.empty-btn {
  margin-top: 32rpx;
  padding: 20rpx 56rpx;
  background: var(--color-ink);
  color: var(--color-bg);
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 8rpx;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.12);
  transition: transform 0.2s ease;
}
.empty-btn:active {
  transform: scale(0.95);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
