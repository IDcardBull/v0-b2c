.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }
.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 20; background: rgba(239,232,220,.9); }
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back { font-size: 56rpx; color: var(--color-ink); }
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-size: 32rpx; letter-spacing: 10rpx; color: var(--color-ink); }
.t-en { font-size: 18rpx; color: var(--color-ink-faint); letter-spacing: 3rpx; }
.tabs { position: fixed; left: 0; right: 0; z-index: 19; height: 86rpx; background: var(--color-bg); display: flex; padding: 0 24rpx; border-bottom: 1rpx solid rgba(58,58,58,.08); }
.tab { flex: 1; display: flex; align-items: center; justify-content: center; font-size: 24rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); }
.tab.on { color: var(--color-ink); }
.card { margin: 24rpx 32rpx 0; padding: 30rpx; background: var(--color-paper); border: 1rpx solid rgba(58,58,58,.08); }
.card-head, .goods, .amount { display: flex; justify-content: space-between; gap: 20rpx; }
.card-head { font-size: 24rpx; color: var(--color-ink-soft); margin-bottom: 20rpx; }
.goods { font-size: 24rpx; color: var(--color-ink); padding: 8rpx 0; }
.amount { margin-top: 20rpx; justify-content: flex-end; font-size: 24rpx; color: var(--color-ink-soft); }
.empty { padding-top: 220rpx; text-align: center; color: var(--color-ink-faint); letter-spacing: 6rpx; }
