<view class="page">
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <text class="back" bindtap="back">‹</text>
      <view class="page-title">
        <text class="t-cn">订单</text>
        <text class="t-en">ORDERS</text>
      </view>
      <view></view>
    </view>
  </view>

  <view class="tabs" style="top: {{statusBarHeight + navBarHeight}}px;">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{current === item.key ? 'tab--on' : ''}}"
      data-key="{{item.key}}"
      bindtap="tapTab"
    >
      <text>{{item.label}}</text>
      <view wx:if="{{current === item.key}}" class="tab-line"></view>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" style="padding-top: {{statusBarHeight + navBarHeight + 86}}px;" bindscrolltolower="loadList">
    <view wx:if="{{list.length === 0}}" class="empty">
      <view class="empty-seal">空</view>
      <text class="empty-cn">暂无订单</text>
      <text class="empty-en">NO ORDER YET</text>
    </view>

    <view wx:for="{{list}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="card-head">
        <text class="order-no">单号 {{item.orderNo || item.id}}</text>
        <text class="status">{{item.statusText}}</text>
      </view>

      <view class="goods-list">
        <view wx:for="{{item.items}}" wx:for-item="goods" wx:key="id" class="goods-row">
          <image class="goods-img" src="{{goods.skuImage || goods.image || goods.cover}}" mode="aspectFill"></image>
          <view class="goods-meta">
            <text class="goods-name">{{goods.productName || goods.name || goods.skuName || '釉见器物'}}</text>
            <text wx:if="{{goods.skuSpec}}" class="goods-spec">{{goods.skuSpec}}</text>
            <view class="goods-bottom">
              <text class="goods-price"><text class="unit">¥</text>{{goods.unitPrice || goods.price}}</text>
              <text class="goods-qty">× {{goods.qty || goods.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="card-foot">
        <text class="card-time">{{item.createdAt}}</text>
        <view class="amount">
          实付 <text class="price"><text class="unit">¥</text>{{item.amount}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{list.length > 0 && finished}}" class="end-text">— 止 —</view>
    <view style="height: 160rpx;"></view>
  </scroll-view>
</view>
