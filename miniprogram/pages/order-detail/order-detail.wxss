.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back {
  font-family: "PingFang SC", sans-serif;
  font-size: 56rpx;
  color: var(--color-ink);
  width: 64rpx;
  text-align: left;
  line-height: 1;
  transition: transform 0.2s ease;
}
.back:active { transform: scale(0.85); }
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-family: "Songti SC", serif; font-size: var(--fs-h2); letter-spacing: 12rpx; color: var(--color-ink); font-weight: 600; }
.t-en { font-family: "PingFang SC", sans-serif; font-size: 20rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); opacity: 0.7; }

/* Hero 状态区 */
.hero {
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
.seal-lg {
  width: 136rpx;
  height: 136rpx;
  border: 1.5rpx solid rgba(138, 175, 166, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 50rpx;
  color: var(--color-ink);
  background: linear-gradient(135deg, var(--color-paper), rgba(184, 207, 200, 0.15));
  box-shadow: var(--shadow-md);
}
.status {
  font-family: "Songti SC", serif;
  font-size: 36rpx;
  letter-spacing: 10rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.order-no {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  letter-spacing: 1rpx;
}

/* Section 卡片化 */
.section {
  margin: 20rpx 32rpx 0;
  padding: 28rpx 32rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.section-title {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.s-cn { font-family: "Songti SC", serif; font-size: 26rpx; letter-spacing: 8rpx; color: var(--color-ink); font-weight: 500; }
.s-en { font-family: "PingFang SC", sans-serif; font-size: 18rpx; letter-spacing: 3rpx; color: var(--color-ink-faint); opacity: 0.7; }

/* 收件 */
.addr-head { display: flex; align-items: baseline; gap: 18rpx; }
.receiver { font-family: "Songti SC", serif; font-size: 30rpx; letter-spacing: 4rpx; color: var(--color-ink); font-weight: 500; }
.phone { font-family: "PingFang SC", sans-serif; font-size: 22rpx; color: var(--color-ink-soft); }
.addr-text { display: block; margin-top: 12rpx; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 2rpx; color: var(--color-ink-soft); line-height: 1.7; }
.addr-edit-btn {
  margin-top: 18rpx;
  width: 260rpx;
  height: 72rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.15);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
  transition: all 0.2s ease;
}
.addr-edit-btn:active {
  background: rgba(58, 58, 58, 0.05);
  transform: scale(0.96);
}

/* 物流 */
.logi-row { display: flex; align-items: center; justify-content: space-between; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 3rpx; color: var(--color-ink); }
.track-no { font-family: "PingFang SC", sans-serif; color: var(--color-ink-soft); font-size: 22rpx; letter-spacing: 1rpx; }
.track-btn {
  margin-top: 20rpx;
  width: 220rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(58, 58, 58, 0.15);
  border-radius: var(--radius-full);
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
  transition: all 0.2s ease;
}
.track-btn:active {
  background: rgba(58, 58, 58, 0.05);
  transform: scale(0.96);
}

/* 商品 */
.goods-row { display: flex; gap: 22rpx; padding: 20rpx 0; border-bottom: 1rpx solid rgba(58, 58, 58, 0.04); }
.goods-row:last-child { border-bottom: none; }
.goods-img { width: 140rpx; height: 160rpx; background: var(--color-card); flex-shrink: 0; border-radius: var(--radius-sm); }
.goods-meta { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.goods-name { font-family: "Songti SC", serif; font-size: 26rpx; letter-spacing: 3rpx; color: var(--color-ink); font-weight: 500; }
.goods-spec {
  align-self: flex-start;
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  background: rgba(184, 207, 200, 0.12);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-xs);
}
.goods-bottom { margin-top: auto; display: flex; align-items: baseline; justify-content: space-between; }
.goods-price { font-family: "DIN Alternate", "PingFang SC", sans-serif; font-size: 26rpx; color: var(--color-ink); font-weight: 600; }
.goods-price .unit { font-size: 20rpx; color: var(--color-ink-soft); margin-right: 2rpx; font-weight: 400; }
.goods-qty { font-family: "PingFang SC", sans-serif; font-size: 22rpx; color: var(--color-ink-soft); }

/* 备注 */
.remark-text { font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 3rpx; color: var(--color-ink); line-height: 1.7; }

/* 款项 */
.sum-row { display: flex; align-items: baseline; justify-content: space-between; padding: 14rpx 0; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 4rpx; color: var(--color-ink-soft); }
.sum-num { font-family: "DIN Alternate", "PingFang SC", sans-serif; font-size: 26rpx; color: var(--color-ink); font-weight: 500; }
.sum-num .unit { font-size: 20rpx; color: var(--color-ink-soft); margin-right: 2rpx; font-weight: 400; }
.sum-divider { height: 1rpx; background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.08), transparent); margin: 14rpx 0; }
.total-row { font-size: 26rpx; color: var(--color-ink); letter-spacing: 6rpx; font-weight: 500; }
.total-num { font-family: "DIN Alternate", "PingFang SC", sans-serif; font-size: 40rpx; color: var(--color-ink); font-weight: 600; }
.total-num .unit { font-size: 22rpx; color: var(--color-ink-soft); margin-right: 4rpx; font-weight: 400; }

/* 时间线 */
.time-row { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; }
.time-label { font-family: "Songti SC", serif; font-size: 22rpx; letter-spacing: 6rpx; color: var(--color-ink-soft); }
.time-value { font-family: "PingFang SC", sans-serif; font-size: 22rpx; color: var(--color-ink-faint); }

.end-text { text-align: center; font-family: "Songti SC", serif; font-size: 22rpx; color: var(--color-ink-faint); letter-spacing: 8rpx; padding: 40rpx 0 20rpx; opacity: 0.7; }
.loading { padding-top: 200rpx; text-align: center; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 6rpx; color: var(--color-ink-faint); }

/* 底栏 */
.bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: rgba(239, 232, 220, 0.95);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-top: 1rpx solid rgba(58, 58, 58, 0.05);
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.05);
  padding: 20rpx 32rpx;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}
.ghost, .primary {
  height: 84rpx;
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  border-radius: var(--radius-sm);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.ghost:active, .primary:active {
  transform: scale(0.95);
  opacity: 0.85;
}
.ghost {
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  color: var(--color-ink);
  background: transparent;
}
.primary {
  background: var(--color-ink);
  color: var(--color-bg);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}
