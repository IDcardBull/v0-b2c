.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 20; background: rgba(239, 232, 220, 0.92); backdrop-filter: blur(20rpx); }
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back { font-family: "PingFang SC", sans-serif; font-size: 56rpx; color: var(--color-ink); width: 64rpx; text-align: left; line-height: 1; }
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-family: "Songti SC", serif; font-size: var(--fs-h2); letter-spacing: 12rpx; color: var(--color-ink); }
.t-en { font-family: "PingFang SC", sans-serif; font-size: 20rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); }

.hero { padding: 60rpx 32rpx 36rpx; display: flex; flex-direction: column; align-items: center; gap: 18rpx; }
.seal-lg { width: 132rpx; height: 132rpx; border: 1rpx solid rgba(58, 58, 58, 0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: "Songti SC", serif; font-size: 50rpx; color: var(--color-ink); background: var(--color-paper); }
.status { font-family: "Songti SC", serif; font-size: 36rpx; letter-spacing: 10rpx; color: var(--color-ink); }
.order-no { font-family: "PingFang SC", sans-serif; font-size: 22rpx; color: var(--color-ink-faint); letter-spacing: 1rpx; }

.section { margin: 24rpx 32rpx 0; padding: 28rpx 32rpx; background: var(--color-paper); border: 1rpx solid rgba(58, 58, 58, 0.08); }
.section-title { display: flex; align-items: baseline; gap: 14rpx; margin-bottom: 20rpx; }
.s-cn { font-family: "Songti SC", serif; font-size: 26rpx; letter-spacing: 8rpx; color: var(--color-ink); }
.s-en { font-family: "PingFang SC", sans-serif; font-size: 18rpx; letter-spacing: 3rpx; color: var(--color-ink-faint); }

.addr-head { display: flex; align-items: baseline; gap: 18rpx; }
.receiver { font-family: "Songti SC", serif; font-size: 30rpx; letter-spacing: 4rpx; color: var(--color-ink); }
.phone { font-family: "PingFang SC", sans-serif; font-size: 22rpx; color: var(--color-ink-soft); }
.addr-text { display: block; margin-top: 12rpx; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 2rpx; color: var(--color-ink-soft); line-height: 1.7; }
.addr-edit-btn { margin-top: 18rpx; width: 260rpx; height: 72rpx; border: 1rpx solid rgba(58,58,58,.22); display: flex; align-items: center; justify-content: center; font-family: "Songti SC", serif; font-size: 22rpx; letter-spacing: 4rpx; color: var(--color-ink-soft); }

.logi-row { display: flex; align-items: center; justify-content: space-between; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 3rpx; color: var(--color-ink); }
.track-no { font-family: "PingFang SC", sans-serif; color: var(--color-ink-soft); font-size: 22rpx; letter-spacing: 1rpx; }
.track-btn { margin-top: 20rpx; width: 220rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(58,58,58,.22); font-family: "Songti SC", serif; font-size: 22rpx; letter-spacing: 6rpx; color: var(--color-ink-soft); }

.goods-row { display: flex; gap: 22rpx; padding: 20rpx 0; border-bottom: 1rpx solid rgba(58, 58, 58, 0.06); }
.goods-row:last-child { border-bottom: none; }
.goods-img { width: 140rpx; height: 160rpx; background: var(--color-card); flex-shrink: 0; }
.goods-meta { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.goods-name { font-family: "Songti SC", serif; font-size: 26rpx; letter-spacing: 3rpx; color: var(--color-ink); }
.goods-spec { align-self: flex-start; font-family: "Songti SC", serif; font-size: 20rpx; letter-spacing: 2rpx; color: var(--color-ink-soft); background: rgba(58, 58, 58, 0.05); padding: 4rpx 12rpx; }
.goods-bottom { margin-top: auto; display: flex; align-items: baseline; justify-content: space-between; }
.goods-price { font-family: "PingFang SC", sans-serif; font-size: 26rpx; color: var(--color-ink); font-weight: 500; }
.goods-price .unit { font-size: 20rpx; color: var(--color-ink-soft); margin-right: 2rpx; }
.goods-qty { font-family: "PingFang SC", sans-serif; font-size: 22rpx; color: var(--color-ink-soft); }

.remark-text { font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 3rpx; color: var(--color-ink); line-height: 1.7; }

.sum-row { display: flex; align-items: baseline; justify-content: space-between; padding: 12rpx 0; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 4rpx; color: var(--color-ink-soft); }
.sum-num { font-family: "PingFang SC", sans-serif; font-size: 26rpx; color: var(--color-ink); }
.sum-num .unit { font-size: 20rpx; color: var(--color-ink-soft); margin-right: 2rpx; }
.sum-divider { height: 1rpx; background: rgba(58,58,58,0.1); margin: 12rpx 0; }
.total-row { font-size: 26rpx; color: var(--color-ink); letter-spacing: 6rpx; }
.total-num { font-family: "PingFang SC", sans-serif; font-size: 38rpx; color: var(--color-ink); font-weight: 500; }
.total-num .unit { font-size: 22rpx; color: var(--color-ink-soft); margin-right: 4rpx; }

.time-row { display: flex; align-items: center; justify-content: space-between; padding: 10rpx 0; }
.time-label { font-family: "Songti SC", serif; font-size: 22rpx; letter-spacing: 6rpx; color: var(--color-ink-soft); }
.time-value { font-family: "PingFang SC", sans-serif; font-size: 22rpx; color: var(--color-ink-faint); }

.end-text { text-align: center; font-family: "Songti SC", serif; font-size: 22rpx; color: var(--color-ink-faint); letter-spacing: 8rpx; padding: 40rpx 0 20rpx; }
.loading { padding-top: 200rpx; text-align: center; font-family: "Songti SC", serif; font-size: 24rpx; letter-spacing: 6rpx; color: var(--color-ink-faint); }

.bar { position: fixed; left: 0; right: 0; bottom: 0; background: rgba(239, 232, 220, 0.96); backdrop-filter: blur(20rpx); border-top: 1rpx solid rgba(58, 58, 58, 0.08); padding: 20rpx 32rpx; display: flex; justify-content: flex-end; gap: 20rpx; }
.ghost, .primary { height: 84rpx; padding: 0 40rpx; display: flex; align-items: center; justify-content: center; font-family: "Songti SC", serif; font-size: 28rpx; letter-spacing: 6rpx; }
.ghost { border: 1rpx solid rgba(58, 58, 58, 0.32); color: var(--color-ink); background: transparent; }
.primary { background: var(--color-ink); color: var(--color-bg); }
