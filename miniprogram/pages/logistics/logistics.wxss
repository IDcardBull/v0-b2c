.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back {
  font-family: "PingFang SC", sans-serif;
  font-size: 56rpx;
  color: var(--color-ink);
  width: 64rpx;
  text-align: left;
  line-height: 1;
  transition: transform 0.2s ease;
}
.back:active { transform: scale(0.85); }
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-family: "Songti SC", serif; font-size: var(--fs-h2); letter-spacing: 12rpx; color: var(--color-ink); font-weight: 600; }
.t-en { font-family: "PingFang SC", sans-serif; font-size: 20rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); opacity: 0.7; }

/* 物流摘要卡 */
.hero-card {
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.hero-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
}
.seal {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  border: 1.5rpx solid var(--color-celadon);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 32rpx;
  color: var(--color-celadon-deep);
  background: rgba(184, 207, 200, 0.1);
  box-shadow: 0 2rpx 12rpx rgba(138, 175, 166, 0.15);
}
.hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.hero-title {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.hero-no {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  word-break: break-all;
}
.copy-btn {
  margin-top: 24rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(58, 58, 58, 0.12);
  border-radius: var(--radius-sm);
  color: var(--color-ink-soft);
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 6rpx;
  transition: all 0.2s ease;
}
.copy-btn:active {
  background: rgba(58, 58, 58, 0.04);
  transform: scale(0.97);
}

/* 空态 */
.empty-state {
  padding: 180rpx 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  animation: fadeInUp 0.5s ease;
}
.empty-text {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
}
.empty-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  color: var(--color-ink-faint);
}

/* 时间轴 */
.timeline {
  margin: 20rpx 32rpx 0;
  padding: 10rpx 32rpx 0;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.trace-item {
  display: flex;
  gap: 20rpx;
}
.trace-axis {
  width: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.trace-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 20rpx;
  border-radius: 50%;
  background: rgba(58, 58, 58, 0.18);
  transition: all 0.3s ease;
}
.trace-line {
  width: 2rpx;
  flex: 1;
  background: linear-gradient(180deg, rgba(58, 58, 58, 0.12), rgba(58, 58, 58, 0.04));
  margin-top: 8rpx;
}
.trace-main {
  flex: 1;
  padding: 14rpx 0 28rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.trace-item:last-child .trace-main { border-bottom: none; }
.trace-item:last-child .trace-line { display: none; }

/* 最新节点高亮 */
.trace-item--latest .trace-dot {
  background: var(--color-celadon-deep);
  width: 18rpx;
  height: 18rpx;
  margin-top: 18rpx;
  box-shadow: 0 0 12rpx rgba(138, 175, 166, 0.4);
}
.trace-item--latest .trace-status {
  color: var(--color-ink);
  font-weight: 500;
}

.trace-status {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  line-height: 1.7;
  letter-spacing: 3rpx;
  color: var(--color-ink-soft);
}
.trace-location {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
}
.trace-time {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  opacity: 0.8;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
