.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
}
.back {
  width: 68rpx; height: 68rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  transition: transform 0.2s ease;
}
.back:active { transform: scale(0.85); }
.back-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 40rpx;
  color: var(--color-ink);
  line-height: 1;
}
.page-title { display: flex; align-items: baseline; gap: 12rpx; }
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

/* 商品摘要 */
.product {
  margin: 24rpx 32rpx 0;
  padding: 28rpx 28rpx;
  display: flex;
  gap: 24rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.product-img {
  width: 144rpx;
  height: 180rpx;
  background: var(--color-card);
  border-radius: var(--radius-sm);
}
.product--empty {
  align-items: center;
}
.product-empty-seal {
  width: 96rpx;
  height: 96rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  background: rgba(246, 241, 230, 0.6);
  box-shadow: var(--shadow-sm);
}
.product-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  justify-content: center;
}
.p-name {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.p-sub {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
}
.p-line {
  margin-top: 6rpx;
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}

.hairline {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.08), transparent);
  margin: 40rpx 32rpx 0;
}

/* 区块 */
.section {
  padding: 36rpx 40rpx 0;
}
.section-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.s-cn {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.s-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}
.counter {
  margin-left: auto;
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  color: var(--color-ink-faint);
}

/* 评分 */
.rating {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 8rpx 0 0;
}
.rating-cell {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(58, 58, 58, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: var(--shadow-sm);
}
.rating-cell:active {
  transform: scale(0.85);
}
.rating-cell--on {
  background: var(--color-celadon-deep);
  border-color: var(--color-celadon-deep);
  box-shadow: 0 2rpx 12rpx rgba(138, 175, 166, 0.3);
}
.r-char {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
}
.rating-cell--on .r-char {
  color: #fff;
}
.rating-text {
  margin-left: 12rpx;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}

/* 文本框 */
.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.05);
  border-radius: var(--radius-sm);
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: var(--color-ink);
  box-sizing: border-box;
}
.ph {
  color: var(--color-ink-faint);
  font-family: "Songti SC", serif;
  letter-spacing: 2rpx;
}

/* 晒图 */
.images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.img-cell {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.img {
  width: 100%;
  height: 100%;
}
.img-del {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 38rpx; height: 38rpx;
  border-radius: 50%;
  background: var(--color-ink);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 26rpx;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(58, 58, 58, 0.2);
}
.img-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 1.5rpx dashed rgba(58, 58, 58, 0.2);
  border-radius: var(--radius-sm);
  transition: background 0.2s ease;
}
.img-add:active {
  background: rgba(184, 207, 200, 0.15);
}
.img-add--loading {
  background: rgba(184, 207, 200, 0.2);
}
.add-cross {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  display: flex; align-items: center; justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: var(--color-ink-soft);
}
.add-text {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}

/* 匿名 */
.anon {
  margin-top: 36rpx;
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.anon-label {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
}

/* 底栏 */
.action {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: rgba(239, 232, 220, 0.95);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  z-index: 30;
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.05);
}
.action-line {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.08), transparent);
  margin: 0 32rpx;
}
.action-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}
.hint {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink-faint);
}
.submit {
  flex: 1;
  max-width: 360rpx;
  padding: 24rpx 0;
  text-align: center;
  background: rgba(58, 58, 58, 0.35);
  color: var(--color-bg);
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 10rpx;
  border-radius: var(--radius-sm);
  transition: all 0.25s ease;
}
.submit--on {
  background: var(--color-ink);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}
.submit--on:active {
  transform: scale(0.96);
  opacity: 0.9;
}
