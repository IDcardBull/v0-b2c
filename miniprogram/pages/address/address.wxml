<view class="page">
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <text class="back" bindtap="back">‹</text>
      <view class="page-title"><text class="t-cn">地址簿</text><text class="t-en">ADDRESS</text></view>
      <text class="edit" bindtap="add">+ 新增</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view wx:if="{{list.length === 0}}" class="empty">
      <view class="empty-seal">址</view>
      <text class="empty-text">尚无收件地址</text>
      <view class="empty-btn" bindtap="add">新增地址</view>
    </view>
    <view class="addr-list">
      <view wx:for="{{list}}" wx:key="id" class="addr-card" data-id="{{item.id}}" bindtap="choose">
        <view class="addr-head"><text class="receiver">{{item.receiver}}</text><text class="phone">{{item.phone}}</text><text wx:if="{{item.isDefault}}" class="seal">默认</text></view>
        <text class="addr-text">{{item.province}}{{item.city}}{{item.district}} {{item.detail}}</text>
        <view class="addr-actions">
          <text data-id="{{item.id}}" catchtap="setDefault">设默认</text>
          <text data-id="{{item.id}}" catchtap="edit">编辑</text>
          <text data-id="{{item.id}}" catchtap="remove">删除</text>
        </view>
      </view>
    </view>
    <view wx:if="{{list.length > 0}}" class="addr-add-card" bindtap="add">
      <text class="addr-add-plus">+</text>
      <text class="addr-add-text">新增收件地址</text>
    </view>
    <view style="height: 160rpx;"></view>
  </scroll-view>

  <view wx:if="{{showForm}}" class="mask" bindtap="closeForm">
    <view class="panel" catchtap="noop">
      <view class="panel-head">
        <text class="panel-title">{{editingId ? '修订地址' : '新增地址'}}</text>
        <text class="panel-sub">DELIVERY ADDRESS</text>
      </view>
      <input class="field-input" placeholder="收件人" value="{{form.receiver}}" data-key="receiver" bindinput="onInput" placeholder-class="ph" />
      <input class="field-input" placeholder="手机号" value="{{form.phone}}" data-key="phone" bindinput="onInput" type="number" maxlength="11" placeholder-class="ph" />

      <picker mode="region" value="{{[form.province, form.city, form.district]}}" bindchange="onRegionChange">
        <view class="region-trigger">
          <text class="region-label">所在地区</text>
          <text class="region-value">{{form.province}} {{form.city}} {{form.district}}</text>
        </view>
      </picker>

      <input class="field-input" placeholder="详细地址" value="{{form.detail}}" data-key="detail" bindinput="onInput" placeholder-class="ph" />
      <input class="field-input" placeholder="标签，如 家 / 公司" value="{{form.tag}}" data-key="tag" bindinput="onInput" placeholder-class="ph" />
      <view class="default-row {{form.isDefault ? 'on' : ''}}" bindtap="onDefault">设为默认地址</view>
      <view class="submit {{saving ? 'submit--loading' : ''}}" bindtap="submit">{{saving ? '保存中…' : '保 存'}}</view>
    </view>
  </view>
</view>
