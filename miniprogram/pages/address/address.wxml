<view class="page">
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <text class="back" bindtap="back">‹</text>
      <view class="page-title"><text class="t-cn">地址簿</text><text class="t-en">ADDRESS</text></view>
      <text class="edit" bindtap="add">新增</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <view wx:if="{{list.length === 0}}" class="empty"><view class="empty-seal">址</view><text>尚无收件地址</text></view>
    <view class="addr-list">
      <view wx:for="{{list}}" wx:key="id" class="addr-card" data-id="{{item.id}}" bindtap="choose">
        <view class="addr-head"><text class="receiver">{{item.receiver}}</text><text class="phone">{{item.phone}}</text><text wx:if="{{item.isDefault}}" class="seal">默认</text></view>
        <text class="addr-text">{{item.province}}{{item.city}}{{item.district}} {{item.detail}}</text>
        <view class="addr-actions">
          <text data-id="{{item.id}}" catchtap="setDefault">设默认</text>
          <text data-id="{{item.id}}" catchtap="edit">编辑</text>
          <text data-id="{{item.id}}" catchtap="remove">删除</text>
        </view>
      </view>
    </view>
    <view style="height: 160rpx;"></view>
  </scroll-view>

  <view wx:if="{{showForm}}" class="mask" bindtap="closeForm">
    <view class="panel" catchtap="noop">
      <view class="panel-title">{{editingId ? '修订地址' : '新增地址'}}</view>
      <input placeholder="收件人" value="{{form.receiver}}" data-key="receiver" bindinput="onInput" />
      <input placeholder="手机号" value="{{form.phone}}" data-key="phone" bindinput="onInput" />
      <input placeholder="省份" value="{{form.province}}" data-key="province" bindinput="onInput" />
      <input placeholder="城市" value="{{form.city}}" data-key="city" bindinput="onInput" />
      <input placeholder="区县" value="{{form.district}}" data-key="district" bindinput="onInput" />
      <input placeholder="详细地址" value="{{form.detail}}" data-key="detail" bindinput="onInput" />
      <input placeholder="标签，如 家 / 公司" value="{{form.tag}}" data-key="tag" bindinput="onInput" />
      <view class="default-row {{form.isDefault ? 'on' : ''}}" bindtap="onDefault">设为默认地址</view>
      <view class="submit" bindtap="submit">保 存</view>
    </view>
  </view>
</view>
