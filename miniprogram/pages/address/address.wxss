.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }
.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 20; background: rgba(239,232,220,.9); backdrop-filter: blur(20rpx); }
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back { font-size: 56rpx; color: var(--color-ink); font-family: "PingFang SC", sans-serif; }
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-family: "Songti SC", serif; font-size: var(--fs-h2); letter-spacing: 12rpx; color: var(--color-ink); }
.t-en { font-size: 20rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); font-family: "PingFang SC", sans-serif; }
.edit { font-family: "Songti SC", serif; font-size: var(--fs-sub); letter-spacing: 6rpx; color: var(--color-ink-soft); }
.addr-list { padding: 24rpx 32rpx; display: flex; flex-direction: column; gap: 24rpx; }
.addr-card { background: var(--color-paper); border: 1rpx solid rgba(58,58,58,.08); padding: 30rpx; }
.addr-head { display: flex; align-items: center; gap: 18rpx; }
.receiver { font-size: 32rpx; letter-spacing: 5rpx; color: var(--color-ink); font-family: "Songti SC", serif; }
.phone, .addr-text { font-size: 24rpx; color: var(--color-ink-soft); font-family: "PingFang SC", sans-serif; }
.addr-text { display: block; margin-top: 16rpx; line-height: 1.8; font-family: "Songti SC", serif; letter-spacing: 2rpx; }
.seal { font-size: 20rpx; padding: 4rpx 12rpx; border: 1rpx solid rgba(58,58,58,.2); color: var(--color-ink-soft); letter-spacing: 3rpx; }
.addr-actions { margin-top: 24rpx; padding-top: 20rpx; border-top: 1rpx dashed rgba(58,58,58,.12); display: flex; justify-content: flex-end; gap: 36rpx; font-size: 22rpx; letter-spacing: 4rpx; color: var(--color-ink-soft); font-family: "Songti SC", serif; }
.addr-actions text { padding: 4rpx 6rpx; }
.panel input { display: block; width: 100%; box-sizing: border-box; padding: 0 4rpx; }
.panel input + input { margin-top: 4rpx; }
.empty { padding-top: 200rpx; display: flex; flex-direction: column; align-items: center; gap: 24rpx; color: var(--color-ink-faint); letter-spacing: 6rpx; font-family: "Songti SC", serif; }
.empty-seal { width: 110rpx; height: 110rpx; border: 1rpx solid rgba(58,58,58,.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-ink); font-family: "Songti SC", serif; font-size: 30rpx; }
.empty-text { font-size: 22rpx; letter-spacing: 8rpx; color: var(--color-ink-faint); }
.empty-btn { margin-top: 16rpx; padding: 18rpx 56rpx; background: var(--color-ink); color: var(--color-bg); font-family: "Songti SC", serif; font-size: 26rpx; letter-spacing: 8rpx; }
.mask { position: fixed; inset: 0; background: rgba(58,58,58,.3); z-index: 40; display: flex; align-items: flex-end; }
.panel { width: 100%; background: var(--color-bg); padding: 40rpx 36rpx calc(env(safe-area-inset-bottom) + 40rpx); border-top: 1rpx solid rgba(58,58,58,.12); }
.panel-title { font-family: "Songti SC", serif; font-size: 34rpx; letter-spacing: 10rpx; color: var(--color-ink); margin-bottom: 28rpx; }
.panel input { height: 86rpx; border-bottom: 1rpx solid rgba(58,58,58,.12); font-size: 28rpx; color: var(--color-ink); font-family: "Songti SC", serif; letter-spacing: 2rpx; }
.default-row { margin-top: 28rpx; font-size: 26rpx; color: var(--color-ink-soft); letter-spacing: 6rpx; font-family: "Songti SC", serif; }
.default-row.on { color: var(--color-ink); }
.submit { margin-top: 40rpx; height: 96rpx; background: var(--color-ink); color: var(--color-bg); display: flex; align-items: center; justify-content: center; font-family: "Songti SC", serif; font-size: 30rpx; letter-spacing: 14rpx; }
