.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back {
  font-size: 56rpx;
  color: var(--color-ink);
  font-family: "PingFang SC", sans-serif;
  transition: transform 0.2s ease;
}
.back:active { transform: scale(0.85); }
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-family: "Songti SC", serif; font-size: var(--fs-h2); letter-spacing: 12rpx; color: var(--color-ink); font-weight: 600; }
.t-en { font-size: 20rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); font-family: "PingFang SC", sans-serif; opacity: 0.7; }
.edit {
  font-family: "Songti SC", serif;
  font-size: var(--fs-sub);
  letter-spacing: 6rpx;
  color: var(--color-celadon-deep);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
}
.edit:active { background: rgba(138, 175, 166, 0.1); }

/* 地址列表 */
.addr-list { padding: 24rpx 32rpx; display: flex; flex-direction: column; gap: 20rpx; }
.addr-card {
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  padding: 30rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}
.addr-card:active { transform: scale(0.98); }
.addr-head { display: flex; align-items: center; gap: 18rpx; flex-wrap: wrap; }
.receiver { font-size: 32rpx; letter-spacing: 5rpx; color: var(--color-ink); font-family: "Songti SC", serif; font-weight: 500; }
.phone { font-size: 24rpx; color: var(--color-ink-soft); font-family: "PingFang SC", sans-serif; }
.addr-text { display: block; margin-top: 16rpx; line-height: 1.8; font-family: "Songti SC", serif; letter-spacing: 2rpx; font-size: 24rpx; color: var(--color-ink-soft); }
.seal {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--color-celadon);
  color: var(--color-celadon-deep);
  letter-spacing: 3rpx;
  border-radius: var(--radius-xs);
  background: rgba(184, 207, 200, 0.1);
}
.addr-actions {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed rgba(58, 58, 58, 0.08);
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
  font-family: "Songti SC", serif;
}
.addr-actions text {
  padding: 6rpx 10rpx;
  border-radius: var(--radius-full);
  transition: background 0.2s ease;
}
.addr-actions text:active { background: rgba(58, 58, 58, 0.05); }

/* 空态 */
.empty {
  padding-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  color: var(--color-ink-faint);
  letter-spacing: 6rpx;
  font-family: "Songti SC", serif;
  animation: fadeInUp 0.5s ease;
}
.empty-seal {
  width: 116rpx;
  height: 116rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-ink);
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  background: rgba(246, 241, 230, 0.6);
  box-shadow: var(--shadow-md);
}
.empty-text { font-size: 22rpx; letter-spacing: 8rpx; color: var(--color-ink-faint); }
.empty-btn {
  margin-top: 16rpx;
  padding: 20rpx 56rpx;
  background: var(--color-ink);
  color: var(--color-bg);
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 8rpx;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.12);
  transition: transform 0.2s ease;
}
.empty-btn:active { transform: scale(0.95); }

/* 弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(30, 28, 24, 0.4);
  z-index: 40;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.25s ease;
}
.panel {
  width: 100%;
  background: var(--color-bg);
  padding: 40rpx 36rpx calc(env(safe-area-inset-bottom) + 40rpx);
  border-top-left-radius: var(--radius-xl);
  border-top-right-radius: var(--radius-xl);
  box-shadow: 0 -12rpx 48rpx rgba(58, 58, 58, 0.1);
  animation: slideUp 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.panel-head { margin-bottom: 28rpx; }
.panel-title { display: block; font-family: "Songti SC", serif; font-size: 34rpx; letter-spacing: 10rpx; color: var(--color-ink); font-weight: 600; }
.panel-sub { display: block; margin-top: 8rpx; font-family: "PingFang SC", sans-serif; font-size: 18rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); opacity: 0.7; }
.field-input {
  display: block;
  width: 100%;
  box-sizing: border-box;
  height: 90rpx;
  padding: 0 8rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.08);
  font-size: 28rpx;
  color: var(--color-ink);
  font-family: "Songti SC", serif;
  letter-spacing: 2rpx;
  transition: border-color 0.2s ease;
}
.field-input + .field-input { margin-top: 4rpx; }
.region-trigger {
  margin-top: 16rpx;
  padding: 22rpx 8rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.08);
}
.region-label { display: block; font-size: 22rpx; letter-spacing: 6rpx; color: var(--color-ink-faint); font-family: "Songti SC", serif; }
.region-value { display: block; margin-top: 10rpx; font-size: 28rpx; color: var(--color-ink); font-family: "Songti SC", serif; letter-spacing: 2rpx; }
.default-row { margin-top: 28rpx; font-size: 26rpx; color: var(--color-ink-soft); letter-spacing: 6rpx; font-family: "Songti SC", serif; }
.default-row.on { color: var(--color-celadon-deep); }
.submit {
  margin-top: 40rpx;
  height: 96rpx;
  background: var(--color-ink);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 14rpx;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.submit:active { transform: scale(0.97); opacity: 0.9; }
.submit--loading { opacity: .65; pointer-events: none; }
.ph { color: var(--color-ink-faint); }

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
