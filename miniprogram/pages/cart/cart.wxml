<view class="page">
  <!-- 顶部 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-inner" style="height: {{navBarHeight}}px;">
      <view class="page-title">
        <text class="t-cn">购物袋</text>
        <text class="t-en">BAG</text>
      </view>
      <text class="edit" bindtap="toggleEdit">{{editing ? '完成' : '管理'}}</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
    <!-- 空态 -->
    <view wx:if="{{list.length === 0}}" class="empty">
      <view class="empty-seal">空</view>
      <text class="empty-cn">袋中尚无一器</text>
      <text class="empty-en">YOUR BAG IS EMPTY</text>
      <view class="empty-btn" bindtap="goHome">
        <text>去挑选 ·</text><text class="arrow">→</text>
      </view>
    </view>

    <!-- 列表 -->
    <block wx:else>
      <view class="list">
        <view
          wx:for="{{list}}"
          wx:key="id"
          class="row"
        >
          <view class="check {{item.checked ? 'check--on' : ''}}"
            data-id="{{item.id}}"
            bindtap="toggleCheck"
          >
            <view wx:if="{{item.checked}}" class="check-dot"></view>
          </view>
          <image class="row-img" src="{{item.cover}}" mode="aspectFill" data-id="{{item.id}}" bindtap="goDetail"></image>
          <view class="row-meta">
            <view class="row-title-row">
              <text class="row-title">{{item.name}}</text>
              <text wx:if="{{item.tag}}" class="seal">{{item.tag}}</text>
            </view>
            <text class="row-sub">{{item.sub}}</text>
            <view class="row-bottom">
              <view class="row-price price">
                <text class="unit">¥</text>{{item.price}}
              </view>
              <view wx:if="{{!editing}}" class="stepper">
                <view class="step" data-id="{{item.id}}" bindtap="dec">−</view>
                <text class="qty">{{item.qty}}</text>
                <view class="step" data-id="{{item.id}}" bindtap="inc">+</view>
              </view>
              <view wx:else class="remove" data-id="{{item.id}}" bindtap="remove">移除</view>
            </view>
          </view>
        </view>
      </view>

      <view class="card-note">
        <view class="note-title">附 · 随函札</view>
        <view class="note-input">
          <input placeholder="为此器题一句话（选填）" placeholder-class="ph" value="{{note}}" bindinput="onNote" />
        </view>
      </view>

      <view class="end-text">— 止 —</view>
      <view style="height: 260rpx;"></view>
    </block>
  </scroll-view>

  <!-- 结算栏 -->
  <view wx:if="{{list.length > 0}}" class="checkout safe-bottom">
    <view class="checkout-line"></view>
    <view class="checkout-inner">
      <view class="all {{allChecked ? 'all--on' : ''}}" bindtap="toggleAll">
        <view class="check {{allChecked ? 'check--on' : ''}}">
          <view wx:if="{{allChecked}}" class="check-dot"></view>
        </view>
        <text>全选</text>
      </view>
      <view class="sum">
        <text class="sum-label">合计</text>
        <text class="sum-price"><text class="unit">¥</text>{{total}}</text>
      </view>
      <view class="pay" bindtap="checkout">
        <text>结 算</text>
        <text wx:if="{{selectedCount > 0}}" class="pay-count">({{selectedCount}})</text>
      </view>
    </view>
  </view>
</view>
