.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.scroll {
  height: 100vh;
  box-sizing: border-box;
}

/* 导航 */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.page-title {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}
.edit {
  font-family: "Songti SC", serif;
  font-size: var(--fs-sub);
  letter-spacing: 6rpx;
  color: var(--color-celadon-deep);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  transition: background 0.2s ease;
}
.edit:active {
  background: rgba(138, 175, 166, 0.1);
}

/* 空态 —— 更加精致 */
.empty {
  padding: 200rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  animation: fadeInUp 0.6s ease;
}
.empty-seal {
  width: 148rpx;
  height: 148rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 48rpx;
  color: var(--color-ink);
  background: rgba(246, 241, 230, 0.6);
  box-shadow: var(--shadow-md);
}
.empty-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
}
.empty-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-faint);
}
.empty-btn {
  margin-top: 24rpx;
  padding: 26rpx 56rpx;
  border: 1.5rpx solid var(--color-ink);
  border-radius: var(--radius-sm);
  font-family: "Songti SC", serif;
  font-size: var(--fs-sub);
  letter-spacing: 10rpx;
  color: var(--color-ink);
  display: flex;
  align-items: center;
  gap: 14rpx;
  transition: all 0.2s ease;
}
.empty-btn:active {
  background: var(--color-ink);
  color: var(--color-bg);
  transform: scale(0.96);
}
.empty-btn .arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 30rpx;
  transition: transform 0.2s ease;
}
.empty-btn:active .arrow {
  transform: translateX(8rpx);
}

/* 地址条 —— 卡片化 */
.addr-bar {
  margin: 24rpx 32rpx 8rpx;
  padding: 28rpx 28rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.05);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}
.addr-bar:active {
  transform: scale(0.98);
}
.addr-bar::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 3rpx;
  background: repeating-linear-gradient(
    90deg,
    var(--color-celadon) 0,
    var(--color-celadon) 12rpx,
    transparent 12rpx,
    transparent 20rpx
  );
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  opacity: 0.6;
}
.addr-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-ink), #4a4a4a);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 0;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(58, 58, 58, 0.15);
}
.addr-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.addr-line-1 {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.addr-name {
  font-family: "Songti SC", serif;
  font-size: var(--fs-body);
  letter-spacing: 4rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.addr-phone {
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx;
  letter-spacing: 1rpx;
  color: var(--color-ink-soft);
}
.addr-line-2 {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.addr-line-2--empty {
  color: var(--color-ink-faint);
}
.addr-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 36rpx;
  color: var(--color-ink-faint);
  flex-shrink: 0;
}

/* 列表 —— 增加卡片感 */
.list {
  padding: 24rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--color-paper);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.row:active {
  transform: scale(0.98);
  box-shadow: none;
}
.check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 1.5rpx solid rgba(58, 58, 58, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  flex-shrink: 0;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.check--on {
  border-color: var(--color-celadon-deep);
  background: var(--color-celadon-deep);
  box-shadow: 0 2rpx 8rpx rgba(138, 175, 166, 0.3);
}
.check-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fff;
  transform: scale(0);
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.check--on .check-dot {
  transform: scale(1);
}
.row-img {
  width: 200rpx;
  height: 220rpx;
  background: var(--color-card);
  flex-shrink: 0;
  border-radius: var(--radius-sm);
}
.row-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 4rpx;
  min-width: 0;
}
.row-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.row-title {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 320rpx;
  font-weight: 500;
}
.seal {
  flex-shrink: 0;
  font-family: "Songti SC", serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-celadon-deep);
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--color-celadon);
  border-radius: var(--radius-xs);
  background: rgba(184, 207, 200, 0.1);
}
.row-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}
.row-spec {
  display: inline-block;
  align-self: flex-start;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
  background: rgba(184, 207, 200, 0.15);
  padding: 6rpx 16rpx;
  margin-top: 4rpx;
  border-radius: var(--radius-xs);
}
.row-bottom {
  margin-top: auto;
  padding-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.row-price {
  font-size: 32rpx;
  font-weight: 600;
}
.stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.step {
  width: 52rpx;
  height: 52rpx;
  border: 1.5rpx solid rgba(58, 58, 58, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: var(--color-ink);
  transition: all 0.2s ease;
}
.step:active {
  background: var(--color-ink);
  color: var(--color-bg);
  border-color: var(--color-ink);
  transform: scale(0.88);
}
.qty {
  font-family: "PingFang SC", sans-serif;
  font-size: 28rpx;
  min-width: 44rpx;
  text-align: center;
  color: var(--color-ink);
  font-weight: 500;
}
.remove {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  color: var(--color-ink-soft);
  letter-spacing: 6rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.15);
  border-radius: var(--radius-full);
  transition: all 0.2s ease;
}
.remove:active {
  background: rgba(58, 58, 58, 0.06);
  transform: scale(0.95);
}

/* 题字卡 —— 卡片化 */
.card-note {
  margin: 36rpx 32rpx 20rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.06);
  background: var(--color-paper);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.note-title {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink-soft);
  margin-bottom: 16rpx;
}
.note-input input {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  color: var(--color-ink);
  letter-spacing: 2rpx;
  height: 56rpx;
}
.ph {
  color: var(--color-ink-faint);
}

.end-text {
  text-align: center;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  letter-spacing: 12rpx;
  padding: 48rpx 0 24rpx;
  opacity: 0.7;
}

/* 结算栏 —— 增强质感 */
.checkout {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 112rpx;
  z-index: 110;
  background: rgba(239, 232, 220, 0.96);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-top: 1rpx solid rgba(58, 58, 58, 0.06);
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.06);
}
.checkout-inner {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  gap: 20rpx;
}
.safe-bar {
  display: none;
}
.all {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
  flex-shrink: 0;
  transition: color 0.2s ease;
}
.all .check {
  margin-top: 0;
  width: 36rpx;
  height: 36rpx;
}
.all--on {
  color: var(--color-ink);
}
.sum {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 12rpx;
  min-width: 0;
}
.sum-label {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  color: var(--color-ink-soft);
  letter-spacing: 6rpx;
}
.sum-price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 44rpx;
  color: var(--color-ink);
  font-weight: 600;
  letter-spacing: 0;
}
.sum-price .unit {
  font-size: 26rpx;
  margin-right: 4rpx;
  color: var(--color-ink-soft);
  font-weight: 400;
}
.pay {
  padding: 22rpx 40rpx;
  background: var(--color-ink);
  color: var(--color-bg);
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 10rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.pay:active {
  transform: scale(0.95);
  opacity: 0.9;
}
.pay-count {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 0;
  color: rgba(239, 232, 220, 0.78);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
