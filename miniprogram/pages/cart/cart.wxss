.page {
  min-height: 100vh;
  background: var(--color-bg);
}
.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: blur(20rpx);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.page-title {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.edit {
  font-family: "Songti SC", serif;
  font-size: var(--fs-sub);
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
}

/* 空态 */
.empty {
  padding: 200rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}
.empty-seal {
  width: 140rpx;
  height: 140rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.32);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 48rpx;
  color: var(--color-ink);
}
.empty-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
}
.empty-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-faint);
}
.empty-btn {
  margin-top: 24rpx;
  padding: 26rpx 56rpx;
  border: 1rpx solid var(--color-ink);
  font-family: "Songti SC", serif;
  font-size: var(--fs-sub);
  letter-spacing: 10rpx;
  color: var(--color-ink);
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.empty-btn .arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 30rpx;
}

/* 地址条 */
.addr-bar {
  margin: 24rpx 32rpx 8rpx;
  padding: 28rpx 28rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.08);
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
}
.addr-bar::before {
  content: '';
  position: absolute;
  inset: 0;
  border-bottom: 1rpx dashed rgba(58, 58, 58, 0.18);
  pointer-events: none;
}
.addr-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-ink);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 0;
  flex-shrink: 0;
}
.addr-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.addr-line-1 {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.addr-name {
  font-family: "Songti SC", serif;
  font-size: var(--fs-body);
  letter-spacing: 4rpx;
  color: var(--color-ink);
}
.addr-phone {
  font-family: "PingFang SC", sans-serif;
  font-size: 24rpx;
  letter-spacing: 1rpx;
  color: var(--color-ink-soft);
}
.addr-line-2 {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.addr-line-2--empty {
  color: var(--color-ink-faint);
}
.addr-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 36rpx;
  color: var(--color-ink-faint);
  flex-shrink: 0;
}

/* 列表 */
.list {
  padding: 24rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}
.row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.08);
}
.check {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(58, 58, 58, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  flex-shrink: 0;
}
.check--on {
  border-color: var(--color-ink);
}
.check-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-ink);
}
.row-img {
  width: 220rpx;
  height: 240rpx;
  background: var(--color-paper);
  flex-shrink: 0;
}
.row-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 6rpx;
  min-width: 0;
}
.row-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.row-title {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h3);
  letter-spacing: 4rpx;
  color: var(--color-ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 320rpx;
}
.seal {
  flex-shrink: 0;
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-soft);
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.18);
}
.row-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
}
.row-spec {
  display: inline-block;
  align-self: flex-start;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
  background: rgba(58, 58, 58, 0.05);
  padding: 6rpx 16rpx;
  margin-top: 4rpx;
}
.row-bottom {
  margin-top: auto;
  padding-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.row-price {
  font-size: 32rpx;
}
.stepper {
  display: flex;
  align-items: center;
  gap: 22rpx;
}
.step {
  width: 52rpx;
  height: 52rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.32);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: var(--color-ink);
}
.qty {
  font-family: "PingFang SC", sans-serif;
  font-size: 28rpx;
  min-width: 44rpx;
  text-align: center;
  color: var(--color-ink);
}
.remove {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  color: var(--color-ink-soft);
  letter-spacing: 6rpx;
  padding: 12rpx 24rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.18);
}

/* 题字卡 */
.card-note {
  margin: 48rpx 32rpx 20rpx;
  padding: 36rpx 32rpx;
  border: 1rpx solid rgba(58, 58, 58, 0.12);
  background: var(--color-paper);
}
.note-title {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink-soft);
  margin-bottom: 16rpx;
}
.note-input input {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  color: var(--color-ink);
  letter-spacing: 2rpx;
  height: 56rpx;
}
.ph {
  color: var(--color-ink-faint);
}

.end-text {
  text-align: center;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  letter-spacing: 12rpx;
  padding: 48rpx 0 24rpx;
}

/* 结算栏（贴底，与 tabBar 互斥） */
.checkout {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 110;
  background: var(--color-bg);
  border-top: 1rpx solid rgba(58, 58, 58, 0.12);
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.06);
}
.checkout-inner {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  gap: 24rpx;
}
.safe-bar {
  height: env(safe-area-inset-bottom);
}
.all {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-soft);
  flex-shrink: 0;
}
.all .check {
  margin-top: 0;
  width: 36rpx;
  height: 36rpx;
}
.all--on {
  color: var(--color-ink);
}
.sum {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 14rpx;
  min-width: 0;
}
.sum-label {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  color: var(--color-ink-soft);
  letter-spacing: 6rpx;
}
.sum-price {
  font-family: "PingFang SC", sans-serif;
  font-size: 44rpx;
  color: var(--color-ink);
  font-weight: 500;
  letter-spacing: 0;
}
.sum-price .unit {
  font-size: 26rpx;
  margin-right: 4rpx;
  color: var(--color-ink-soft);
}
.pay {
  padding: 22rpx 44rpx;
  background: var(--color-ink);
  color: var(--color-bg);
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.pay-count {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  letter-spacing: 0;
  color: rgba(239, 232, 220, 0.78);
}
