.page { min-height: 100vh; background: var(--color-bg); }
.scroll { height: 100vh; box-sizing: border-box; }

.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 20;
  background: rgba(239, 232, 220, 0.92);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
}
.back {
  font-family: "PingFang SC", sans-serif;
  font-size: 56rpx;
  color: var(--color-ink);
  width: 64rpx;
  text-align: left;
  line-height: 1;
  transition: transform 0.2s ease;
}
.back:active {
  transform: scale(0.85);
}
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

/* 地址卡 —— 卡片化 */
.addr-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 28rpx 32rpx 0;
  padding: 36rpx 32rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}
.addr-card:active {
  transform: scale(0.98);
}
.addr-mark {
  width: 68rpx;
  height: 68rpx;
  border: 1.5rpx solid var(--color-celadon-deep);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  color: var(--color-celadon-deep);
  flex-shrink: 0;
  background: rgba(184, 207, 200, 0.1);
}
.addr-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}
.addr-head {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  flex-wrap: wrap;
}
.receiver {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.phone {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-soft);
}
.addr-tag {
  font-family: "Songti SC", serif;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--color-celadon-deep);
  padding: 2rpx 10rpx;
  border: 1rpx solid var(--color-celadon);
  border-radius: var(--radius-xs);
  background: rgba(184, 207, 200, 0.1);
}
.addr-text {
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  line-height: 1.7;
}
.placeholder {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.addr-arrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 36rpx;
  color: var(--color-ink-faint);
  flex-shrink: 0;
}

/* 区块 —— 卡片化 */
.section {
  margin: 20rpx 32rpx 0;
  padding: 32rpx;
  background: var(--color-paper);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.section-title {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-bottom: 24rpx;
}
.s-cn {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.s-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}

/* 器物 */
.item {
  display: flex;
  gap: 22rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.04);
}
.item:last-child { border-bottom: none; }
.item-img {
  width: 160rpx;
  height: 180rpx;
  background: var(--color-card);
  flex-shrink: 0;
  border-radius: var(--radius-sm);
}
.item-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.item-name {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.item-spec {
  align-self: flex-start;
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-soft);
  background: rgba(184, 207, 200, 0.12);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
}
.item-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  color: var(--color-ink-faint);
}
.item-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: auto;
}
.item-price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 30rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.item-price .unit {
  font-size: 22rpx;
  color: var(--color-ink-soft);
  margin-right: 4rpx;
  font-weight: 400;
}
.item-qty {
  font-family: "PingFang SC", sans-serif;
  font-size: 22rpx;
  color: var(--color-ink-soft);
}

/* 留言 */
.remark-input {
  height: 76rpx;
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  color: var(--color-ink);
  letter-spacing: 2rpx;
  border-bottom: 1rpx solid rgba(58, 58, 58, 0.06);
}
.ph { color: var(--color-ink-faint); }

/* 款项 */
.sum-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 16rpx 0;
  font-family: "Songti SC", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.sum-num {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 26rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.sum-num .unit {
  font-size: 20rpx;
  color: var(--color-ink-soft);
  margin-right: 2rpx;
  font-weight: 400;
}
.sum-tip {
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  text-align: right;
}
.sum-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.08), transparent);
  margin: 16rpx 0;
}
.total-row {
  font-size: 26rpx;
  color: var(--color-ink);
  letter-spacing: 6rpx;
  font-weight: 500;
}
.total-num {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 40rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.total-num .unit {
  font-size: 22rpx;
  color: var(--color-ink-soft);
  margin-right: 4rpx;
  font-weight: 400;
}

.end-text {
  text-align: center;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  color: var(--color-ink-faint);
  letter-spacing: 8rpx;
  padding: 40rpx 0 20rpx;
  opacity: 0.7;
}

/* 底栏 —— 增强质感 */
.bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: rgba(239, 232, 220, 0.95);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-top: 1rpx solid rgba(58, 58, 58, 0.06);
  box-shadow: 0 -4rpx 24rpx rgba(58, 58, 58, 0.05);
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.sum-mini {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  justify-content: flex-end;
}
.sum-label {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.sum-mini-price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 40rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.sum-mini-price .unit {
  font-size: 22rpx;
  color: var(--color-ink-soft);
  margin-right: 4rpx;
  font-weight: 400;
}
.submit {
  min-width: 280rpx;
  height: 92rpx;
  padding: 0 36rpx;
  background: var(--color-ink);
  color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 8rpx;
  border-radius: var(--radius-sm);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
  transition: transform 0.2s ease, opacity 0.2s ease;
}
.submit:active {
  transform: scale(0.96);
  opacity: 0.9;
}
.submit--ing { opacity: 0.5; pointer-events: none; }
