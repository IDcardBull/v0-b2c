.page { min-height: 100vh; background: var(--color-bg); }
.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 20; background: rgba(239,232,220,.9); backdrop-filter: blur(20rpx); }
.navbar-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 40rpx; }
.back { font-size: 56rpx; color: var(--color-ink); font-family: "PingFang SC", sans-serif; }
.page-title { display: flex; align-items: baseline; gap: 14rpx; }
.t-cn { font-family: "Songti SC", serif; font-size: 32rpx; letter-spacing: 10rpx; color: var(--color-ink); }
.t-en { font-family: "PingFang SC", sans-serif; font-size: 18rpx; letter-spacing: 3rpx; color: var(--color-ink-faint); }
.login-wrap { min-height: 100vh; padding-left: 48rpx; padding-right: 48rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 28rpx; }
.seal-lg { width: 148rpx; height: 148rpx; border: 1rpx solid rgba(58,58,58,.42); display: flex; align-items: center; justify-content: center; font-family: "Songti SC", serif; font-size: 34rpx; letter-spacing: 6rpx; color: var(--color-ink); writing-mode: vertical-rl; }
.title { font-family: "Songti SC", serif; font-size: 40rpx; letter-spacing: 16rpx; color: var(--color-ink); margin-top: 20rpx; }
.sub, .hint { font-size: 22rpx; letter-spacing: 4rpx; color: var(--color-ink-faint); font-family: "Songti SC", serif; text-align: center; }
.login-btn { margin-top: 40rpx; width: 520rpx; height: 96rpx; background: var(--color-ink); color: var(--color-bg); display: flex; align-items: center; justify-content: center; font-family: "Songti SC", serif; font-size: 28rpx; letter-spacing: 8rpx; }
