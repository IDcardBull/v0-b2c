.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255,255,255,.38) 0, rgba(255,255,255,0) 34%),
    linear-gradient(180deg, #f4ede2 0%, #efe8dc 52%, #ece3d6 100%);
  position: relative;
  overflow: hidden;
}
.bg-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,.24);
  filter: blur(10rpx);
}
.bg-orb--1 {
  width: 280rpx;
  height: 280rpx;
  top: 140rpx;
  right: -80rpx;
}
.bg-orb--2 {
  width: 220rpx;
  height: 220rpx;
  bottom: 200rpx;
  left: -70rpx;
  background: rgba(214, 226, 220, .24);
}
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(239,232,220,.62);
  backdrop-filter: blur(24rpx);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 34rpx;
}
.back-wrap, .nav-placeholder {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back {
  font-size: 52rpx;
  color: var(--color-ink);
  font-family: "PingFang SC", sans-serif;
}
.page-title {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.login-wrap {
  min-height: 100vh;
  padding: 26rpx 28rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.hero-card {
  width: 100%;
  padding: 40rpx 30rpx 34rpx;
  background: rgba(246, 241, 230, 0.94);
  border: 1rpx solid rgba(58,58,58,.07);
  box-shadow: 0 20rpx 60rpx rgba(58,58,58,.08);
}
.hero-top {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}
.seal-col {
  width: 170rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.seal-lg {
  width: 132rpx;
  height: 132rpx;
  border: 1rpx solid rgba(58,58,58,.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  background: rgba(255,255,255,.42);
}
.brand-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 16rpx;
  line-height: 1.6;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  text-align: center;
}
.hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 8rpx;
}
.eyebrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 16rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.title {
  font-family: "Songti SC", serif;
  font-size: 42rpx;
  letter-spacing: 14rpx;
  color: var(--color-ink);
  padding-left: 14rpx;
}
.sub {
  font-size: 22rpx;
  line-height: 1.9;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  font-family: "Songti SC", serif;
}
.divider {
  height: 1rpx;
  background: rgba(58,58,58,.08);
  margin: 28rpx 0;
}
.auth-card {
  padding: 28rpx 24rpx;
  background: rgba(255,255,255,.28);
  border: 1rpx solid rgba(58,58,58,.06);
}
.auth-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}
.auth-title {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
}
.auth-tip {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.avatar-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.avatar-picker {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  padding: 0;
  border-radius: 50%;
  background: var(--color-paper);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}
.avatar-picker::after {
  border: none;
}
.avatar-img {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}
.avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-empty-char {
  font-family: "Songti SC", serif;
  font-size: 34rpx;
  color: var(--color-ink-soft);
}
.avatar-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.avatar-title {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
}
.avatar-desc {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
}
.avatar-action {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  background: rgba(58,58,58,.06);
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
}
.nick-field {
  margin-top: 28rpx;
  padding: 18rpx 22rpx 0;
  background: rgba(246,241,230,.76);
  border: none;
}
.nick-field--filled {
  border-color: transparent;
}
.field-label {
  display: block;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-faint);
}
.nick-input {
  height: 76rpx;
  box-sizing: border-box;
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
}
.hint-row {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}
.hint-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-ink-faint);
  margin-top: 12rpx;
  flex-shrink: 0;
}
.hint {
  flex: 1;
  font-size: 20rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  font-family: "Songti SC", serif;
}
.login-btn {
  margin-top: 28rpx;
  width: 100%;
  min-height: 104rpx;
  background: linear-gradient(180deg, #484848 0%, #343434 100%);
  color: var(--color-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: opacity .2s ease;
}
.login-btn--disabled {
  opacity: .45;
}
.login-btn--loading {
  opacity: .72;
}
.login-btn-main {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 10rpx;
}
.login-btn-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(239,232,220,.72);
}
.bottom-copy {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.8;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  font-family: "Songti SC", serif;
  text-align: center;
}
.ph {
  color: var(--color-ink-faint);
}
