/* =====================================================
   登录页 — 釉见陶瓷 B2C
   简洁优雅的中式风格登录体验
   ===================================================== */

.page {
  min-height: 100vh;
  background: linear-gradient(165deg, #f7f1e8 0%, #f0e8db 40%, #ebe2d4 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰层 */
.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.bg-circle--1 {
  width: 480rpx;
  height: 480rpx;
  top: -120rpx;
  right: -160rpx;
  background: radial-gradient(circle, rgba(138, 175, 166, 0.15) 0%, transparent 70%);
  animation: float 8s ease-in-out infinite;
}

.bg-circle--2 {
  width: 360rpx;
  height: 360rpx;
  bottom: 100rpx;
  left: -120rpx;
  background: radial-gradient(circle, rgba(200, 168, 130, 0.12) 0%, transparent 70%);
  animation: float 10s ease-in-out infinite reverse;
}

.bg-circle--3 {
  width: 200rpx;
  height: 200rpx;
  top: 40%;
  right: 10%;
  background: radial-gradient(circle, rgba(138, 175, 166, 0.08) 0%, transparent 70%);
  animation: float 6s ease-in-out infinite 2s;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.03); }
}

/* 导航栏 */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.navbar-inner {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.back-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.8);
}

.back-icon {
  font-size: 44rpx;
  color: #3a3a3a;
  font-weight: 300;
  margin-top: -4rpx;
}

/* 主内容 */
.content {
  position: relative;
  z-index: 1;
  padding: 0 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 48rpx;
  margin-bottom: 56rpx;
}

.brand-seal {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.seal-char {
  font-family: "Songti SC", "STSong", serif;
  font-size: 72rpx;
  font-weight: 600;
  color: #3a3a3a;
  letter-spacing: 4rpx;
}

.seal-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8aafa6, #6d9a8f);
  box-shadow: 0 2rpx 8rpx rgba(138, 175, 166, 0.4);
}

.brand-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.brand-slogan {
  font-family: "Songti SC", "STSong", serif;
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: rgba(58, 58, 58, 0.5);
}

/* 登录卡片 */
.login-card {
  width: 100%;
  padding: 48rpx 40rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 32rpx;
  box-shadow:
    0 16rpx 48rpx rgba(58, 58, 58, 0.06),
    0 4rpx 16rpx rgba(58, 58, 58, 0.03);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
}

.card-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.card-title {
  display: block;
  font-family: "Songti SC", "STSong", serif;
  font-size: 36rpx;
  font-weight: 600;
  color: #3a3a3a;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(58, 58, 58, 0.45);
  letter-spacing: 2rpx;
}

/* 头像选择 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.avatar-btn {
  width: 144rpx;
  height: 144rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0ebe3, #e8e0d5);
  border: 3rpx dashed rgba(138, 175, 166, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(58, 58, 58, 0.06);
}

.avatar-btn::after {
  border: none;
}

.avatar-btn:active {
  transform: scale(0.93);
}

.avatar-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-plus {
  font-size: 48rpx;
  color: rgba(138, 175, 166, 0.7);
  font-weight: 300;
  line-height: 1;
}

.avatar-status {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(58, 58, 58, 0.4);
  letter-spacing: 2rpx;
}

/* 昵称输入 */
.input-group {
  margin-bottom: 40rpx;
}

.input-wrapper {
  padding: 20rpx 24rpx;
  background: rgba(246, 241, 230, 0.6);
  border: 1rpx solid rgba(58, 58, 58, 0.06);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.input-wrapper--active {
  border-color: rgba(138, 175, 166, 0.5);
  background: rgba(255, 255, 255, 0.5);
  box-shadow: 0 0 0 3rpx rgba(138, 175, 166, 0.1);
}

.input-label {
  display: block;
  font-family: "Songti SC", "STSong", serif;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: rgba(58, 58, 58, 0.4);
  margin-bottom: 4rpx;
}

.nick-input {
  height: 64rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 30rpx;
  color: #3a3a3a;
  letter-spacing: 2rpx;
}

.input-ph {
  color: rgba(58, 58, 58, 0.25);
  font-family: "Songti SC", "STSong", serif;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #d4d0ca, #c8c2ba);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.submit-btn--active {
  background: linear-gradient(135deg, #4a4a4a, #3a3a3a);
  box-shadow: 0 8rpx 32rpx rgba(58, 58, 58, 0.2);
}

.submit-btn--active:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(58, 58, 58, 0.15);
}

.submit-btn--loading {
  opacity: 0.7;
  pointer-events: none;
}

.submit-text {
  font-family: "Songti SC", "STSong", serif;
  font-size: 30rpx;
  letter-spacing: 8rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.submit-btn:not(.submit-btn--active) .submit-text {
  color: rgba(58, 58, 58, 0.35);
}

/* 隐私提示 */
.privacy-hint {
  margin-top: 24rpx;
  text-align: center;
}

.privacy-text {
  font-size: 20rpx;
  color: rgba(58, 58, 58, 0.3);
  letter-spacing: 1rpx;
}

/* 底部 */
.footer {
  margin-top: 64rpx;
  text-align: center;
}

.footer-text {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(58, 58, 58, 0.2);
  font-weight: 300;
}
