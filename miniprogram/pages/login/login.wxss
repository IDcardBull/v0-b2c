.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255,255,255,.42) 0, rgba(255,255,255,0) 34%),
    linear-gradient(180deg, #f4ede2 0%, #efe8dc 52%, #ece3d6 100%);
  position: relative;
  overflow: hidden;
}
.bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(16rpx);
}
.bg-orb--1 {
  width: 320rpx;
  height: 320rpx;
  top: 120rpx;
  right: -100rpx;
  background: rgba(184, 207, 200, .18);
}
.bg-orb--2 {
  width: 260rpx;
  height: 260rpx;
  bottom: 180rpx;
  left: -80rpx;
  background: rgba(200, 168, 130, .12);
}
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: rgba(239,232,220,.65);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
}
.navbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 34rpx;
}
.back-wrap, .nav-placeholder {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back {
  font-size: 52rpx;
  color: var(--color-ink);
  font-family: "PingFang SC", sans-serif;
  transition: transform 0.2s ease;
}
.back:active {
  transform: scale(0.85);
}
.page-title {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.t-cn {
  font-family: "Songti SC", serif;
  font-size: var(--fs-h2);
  letter-spacing: 12rpx;
  color: var(--color-ink);
  font-weight: 600;
}
.t-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  opacity: 0.7;
}
.login-wrap {
  min-height: 100vh;
  padding: 26rpx 28rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.hero-card {
  width: 100%;
  padding: 44rpx 32rpx 38rpx;
  background: rgba(246, 241, 230, 0.95);
  border: 1rpx solid rgba(58,58,58,.05);
  box-shadow: 0 24rpx 72rpx rgba(58,58,58,.1), 0 8rpx 24rpx rgba(58,58,58,.04);
  border-radius: var(--radius-lg);
  backdrop-filter: blur(8rpx);
}
.hero-top {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}
.seal-col {
  width: 170rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}
.seal-lg {
  width: 136rpx;
  height: 136rpx;
  border: 1.5rpx solid rgba(58,58,58,.2);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink);
  background: rgba(255,255,255,.5);
  box-shadow: var(--shadow-sm);
  transform: rotate(-2deg);
}
.brand-en {
  font-family: "PingFang SC", sans-serif;
  font-size: 16rpx;
  line-height: 1.6;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
  text-align: center;
  opacity: 0.8;
}
.hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 8rpx;
}
.eyebrow {
  font-family: "PingFang SC", sans-serif;
  font-size: 16rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.title {
  font-family: "Songti SC", serif;
  font-size: 42rpx;
  letter-spacing: 14rpx;
  color: var(--color-ink);
  padding-left: 14rpx;
  font-weight: 600;
}
.sub {
  font-size: 22rpx;
  line-height: 1.9;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
  font-family: "Songti SC", serif;
}
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(58,58,58,.08), transparent);
  margin: 32rpx 0;
}
.auth-card {
  padding: 32rpx 28rpx;
  background: rgba(255,255,255,.32);
  border: 1rpx solid rgba(58,58,58,.04);
  border-radius: var(--radius-md);
}
.auth-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}
.auth-title {
  font-family: "Songti SC", serif;
  font-size: 28rpx;
  letter-spacing: 8rpx;
  color: var(--color-ink);
  font-weight: 500;
}
.auth-tip {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-faint);
}
.avatar-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.avatar-picker {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  padding: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-celadon-light), var(--color-celadon));
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(138, 175, 166, 0.2);
  transition: transform 0.2s ease;
}
.avatar-picker:active {
  transform: scale(0.92);
}
.avatar-picker::after {
  border: none;
}
.avatar-img {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
}
.avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-empty-char {
  font-family: "Songti SC", serif;
  font-size: 34rpx;
  color: var(--color-ink);
}
.avatar-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.avatar-title {
  font-family: "Songti SC", serif;
  font-size: 26rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink);
}
.avatar-desc {
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: var(--color-ink-soft);
}
.avatar-action {
  align-self: flex-start;
  padding: 8rpx 18rpx;
  background: rgba(58,58,58,.05);
  border-radius: var(--radius-full);
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-ink-soft);
  transition: background 0.2s ease;
}
.avatar-action:active {
  background: rgba(58,58,58,.1);
}
.nick-field {
  margin-top: 28rpx;
  padding: 18rpx 22rpx 0;
  background: rgba(246,241,230,.8);
  border: 1rpx solid rgba(58, 58, 58, 0.04);
  border-radius: var(--radius-sm);
}
.nick-field--filled {
  border-color: var(--color-celadon);
}
.field-label {
  display: block;
  font-family: "Songti SC", serif;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--color-ink-faint);
}
.nick-input {
  height: 76rpx;
  box-sizing: border-box;
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  color: var(--color-ink);
}
.hint-row {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}
.hint-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-celadon-deep);
  margin-top: 12rpx;
  flex-shrink: 0;
}
.hint {
  flex: 1;
  font-size: 20rpx;
  line-height: 1.8;
  letter-spacing: 2rpx;
  color: var(--color-ink-faint);
  font-family: "Songti SC", serif;
}
.login-btn {
  margin-top: 32rpx;
  width: 100%;
  min-height: 104rpx;
  background: linear-gradient(180deg, #484848 0%, #343434 100%);
  color: var(--color-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: var(--radius-sm);
  box-shadow: 0 6rpx 24rpx rgba(58, 58, 58, 0.2);
  transition: transform 0.2s ease, opacity .2s ease;
}
.login-btn:active {
  transform: scale(0.97);
}
.login-btn--disabled {
  opacity: .4;
  pointer-events: none;
}
.login-btn--loading {
  opacity: .7;
}
.login-btn-main {
  font-family: "Songti SC", serif;
  font-size: 30rpx;
  letter-spacing: 10rpx;
}
.login-btn-sub {
  font-family: "PingFang SC", sans-serif;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(239,232,220,.72);
}
.bottom-copy {
  margin-top: 20rpx;
  font-size: 22rpx;
  line-height: 1.8;
  letter-spacing: 3rpx;
  color: var(--color-ink-faint);
  font-family: "Songti SC", serif;
  text-align: center;
  opacity: 0.8;
}
.ph {
  color: var(--color-ink-faint);
}
