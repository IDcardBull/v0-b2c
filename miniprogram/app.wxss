/* app.wxss —— 釉见陶瓷 · 全局设计体系 v2.0
 * 主色：淡青 #B8CFC8
 * 底色：米宣 #EFE8DC / #F6F1E6
 * 炭灰 #3A3A3A / 次文 #6B6B6B
 * 字体：Songti SC / PingFang SC
 * 优化：增加阴影层次、动效、渐变、精致度
 */

page {
  --color-bg: #EFE8DC;
  --color-paper: #F6F1E6;
  --color-card: #ECE4D4;
  --color-ink: #3A3A3A;
  --color-ink-soft: #6B6B6B;
  --color-ink-faint: #A69F92;
  --color-celadon: #B8CFC8;
  --color-celadon-deep: #8AAFA6;
  --color-celadon-light: #D4E5E0;
  --color-line: rgba(58, 58, 58, 0.08);
  --color-warm: #C8A882;
  --color-warm-light: #E8D5C0;

  /* 阴影体系 */
  --shadow-sm: 0 2rpx 8rpx rgba(58, 58, 58, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(58, 58, 58, 0.06), 0 2rpx 6rpx rgba(58, 58, 58, 0.03);
  --shadow-lg: 0 8rpx 32rpx rgba(58, 58, 58, 0.08), 0 4rpx 12rpx rgba(58, 58, 58, 0.04);
  --shadow-xl: 0 16rpx 48rpx rgba(58, 58, 58, 0.1), 0 6rpx 20rpx rgba(58, 58, 58, 0.05);

  /* 圆角体系 */
  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;

  background: var(--color-bg);
  color: var(--color-ink);
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  font-size: 30rpx;
  line-height: 1.65;
  letter-spacing: 1rpx;

  /* 全局字号 token */
  --fs-display: 56rpx;
  --fs-h1: 44rpx;
  --fs-h2: 36rpx;
  --fs-h3: 32rpx;
  --fs-body: 30rpx;
  --fs-sub: 26rpx;
  --fs-mini: 22rpx;
  --ls-tight: 1rpx;
  --ls-normal: 4rpx;
  --ls-wide: 8rpx;

  /* 动效 */
  --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --duration-fast: 0.2s;
  --duration-normal: 0.3s;
  --duration-slow: 0.45s;
}

view,
text,
image {
  box-sizing: border-box;
}

.sans {
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.hairline {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--color-line) 20%, var(--color-line) 80%, transparent);
}

.divider-seal {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 48rpx 0;
  color: var(--color-ink-faint);
  font-size: 22rpx;
  letter-spacing: 8rpx;
}

.divider-seal::before,
.divider-seal::after {
  content: "";
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(58, 58, 58, 0.12), transparent);
}

.price {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  color: var(--color-ink);
  font-weight: 500;
  letter-spacing: 0;
}

.price .unit {
  font-size: 24rpx;
  color: var(--color-ink-soft);
  margin-right: 4rpx;
  font-weight: 400;
}

.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* 统一按钮重置 */
button {
  background: transparent;
  padding: 0;
  border-radius: 0;
  line-height: inherit;
  font-size: inherit;
}
button::after {
  border: none;
}

/* 通用点击态 */
.tap-active {
  transition: transform var(--duration-fast) var(--ease-out), opacity var(--duration-fast);
}
.tap-active:active {
  transform: scale(0.97);
  opacity: 0.85;
}

/* 通用淡入动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.92);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
